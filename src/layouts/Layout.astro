---
interface Props {
	title: string;
	hideNav?: boolean;
	noMainWrapper?: boolean;
}

const { title, hideNav, noMainWrapper } = Astro.props;
const isAdmin = Astro.url.pathname.startsWith('/admin');
---

<!doctype html>
<html lang="nl">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="KVVI - Koninklijke Vrije Vissers Izegem" />
		<meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title} | KVVI</title>
	</head>
	<body class="bg-gray-50 text-slate-900 font-sans antialiased">
		{!hideNav && (
		<nav class="bg-kvvi-blue text-white sticky top-0 z-50 shadow-md">
			<div class="max-w-7xl mx-auto px-4 h-14 flex justify-between items-center">
				<a href="/" class="text-xl font-bold tracking-tight">KVVI IZEGEM</a>
				<div class="space-x-6 hidden md:flex items-center">
					<a href="/uitslagen/Zaterdagvissers" class="hover:text-kvvi-gold transition">Wedstrijden</a>
					<a href="/hengelmap" class="hover:text-kvvi-gold transition">Hengelmap</a>
				</div>
				<button class="md:hidden p-2" id="menu-btn" aria-label="Menu">
					<svg id="menu-icon-open" xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7" />
					</svg>
					<svg id="menu-icon-close" xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
					</svg>
				</button>
			</div>
			<div id="mobile-menu" class="md:hidden hidden bg-kvvi-blue border-t border-blue-700/50">
				<div class="px-4 py-3 space-y-2">
					<a href="/uitslagen/Zaterdagvissers" class="block py-2 px-3 rounded-lg hover:bg-blue-800 transition" onclick="sluitMenu()">Wedstrijden</a>
					<a href="/hengelmap" class="block py-2 px-3 rounded-lg hover:bg-blue-800 transition" onclick="sluitMenu()">Hengelmap</a>
				</div>
			</div>
		</nav>
		)}
		<div id="menu-backdrop" class="md:hidden hidden fixed inset-0 bg-black/30 z-40" onclick="sluitMenu()"></div>

		<script>
		function sluitMenu() {
			document.getElementById('mobile-menu')?.classList.add('hidden');
			document.getElementById('menu-backdrop')?.classList.add('hidden');
			document.getElementById('menu-icon-open')?.classList.remove('hidden');
			document.getElementById('menu-icon-close')?.classList.add('hidden');
		}
		document.addEventListener('DOMContentLoaded', function() {
			var btn = document.getElementById('menu-btn');
			if (!btn) return;
			btn.addEventListener('click', function() {
				var menu = document.getElementById('mobile-menu');
				var backdrop = document.getElementById('menu-backdrop');
				var openIcon = document.getElementById('menu-icon-open');
				var closeIcon = document.getElementById('menu-icon-close');
				if (!menu) return;
				var isOpen = !menu.classList.contains('hidden');
				menu.classList.toggle('hidden');
				backdrop?.classList.toggle('hidden');
				openIcon?.classList.toggle('hidden');
				closeIcon?.classList.toggle('hidden');
			});
		});
		</script>

		{hideNav || noMainWrapper ? (
			<slot />
		) : (
			<main class="max-w-7xl mx-auto p-4 md:p-8">
				<slot />
			</main>
		)}

		{!hideNav && !noMainWrapper && (
		<footer class="bg-slate-900 text-slate-400 p-8 mt-12 text-center text-sm">
			<p>&copy; {new Date().getFullYear()} KVVI Izegem - Gebouwd voor de hengelsport.</p>
		</footer>
		)}

		{isAdmin && (
		<div class="fixed bottom-4 right-4 left-4 z-50 flex justify-end gap-1.5" style="pointer-events:none">
			<div class="flex flex-col items-end gap-1.5" style="pointer-events:auto">
				<a href="/admin/logout" class="bg-red-600 text-white text-[10px] font-bold px-3 py-1.5 rounded-full shadow-lg hover:bg-red-700 transition">
					🚪 Uitloggen
				</a>
				<div id="bezoekers-badge" class="bg-[#003366] text-white text-[10px] font-bold px-3 py-1.5 rounded-full shadow-lg flex items-center gap-1.5">
					<span>👁️</span>
					<span id="bezoekers-count">--</span>
					<span>bezoekers</span>
				</div>
			</div>
		</div>
		)}

		<script>
		(function() {
			var badge = document.getElementById('bezoekers-count');
			if (!badge) return;
			fetch('/api/bezoekers').then(function(r){return r.json();}).then(function(d){
				badge.textContent = d.count || 0;
			}).catch(function(){
				badge.textContent = '?';
			});
		})();
		</script>
</body>
</html>

<style is:global>
	/* Optimalisatie voor iOS: voorkom 'grey highlight' bij klikken */
	* {
		-webkit-tap-highlight-color: transparent;
	}
</style>