---
import BaseLayout from '../layouts/BaseLayout.astro';
export const prerender = false;
---

<BaseLayout title="Hengel-Assistent" description="AI-gestuurde hengel-assistent voor vissers. Stel vragen over visstekken, weersomstandigheden en visstrategieën in West-Vlaanderen.">
  <main class="assistent-page">
    <div class="chat-container">
      <div class="chat-header">
        <div class="chat-header-left">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#C5A059" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 2a7 7 0 0 0-7 7c0 5.25 7 13 7 13s7-7.75 7-13a7 7 0 0 0-7-7z"/>
            <circle cx="12" cy="9" r="2.5"/>
          </svg>
          <div>
            <div class="chat-title">KVVI Hengel-Assistent</div>
            <div class="chat-status" id="chat-status">Controleren...</div>
          </div>
        </div>
      </div>

      <div class="chat-messages" id="chat-messages">
        <div class="msg msg-bot">
          <div class="msg-avatar">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#C5A059" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 2a7 7 0 0 0-7 7c0 5.25 7 13 7 13s7-7.75 7-13a7 7 0 0 0-7-7z"/>
              <circle cx="12" cy="9" r="2.5"/>
            </svg>
          </div>
          <div class="msg-content">
            <div class="msg-text">Hallo! Ik ben de KVVI Hengel-Assistent. Stel me een vraag over vissen, visstekken, weersomstandigheden of de club.</div>
          </div>
        </div>
      </div>

      <div class="chat-typing" id="chat-typing">
        <span class="typing-dot"></span>
        <span class="typing-dot"></span>
        <span class="typing-dot"></span>
      </div>

      <div class="chat-input-row">
        <textarea class="chat-input" id="chat-input" rows="1" placeholder="Stel een vraag over vissen..." maxlength="1000"></textarea>
        <button class="chat-send" id="chat-send" aria-label="Verzend">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <line x1="22" y1="2" x2="11" y2="13"/>
            <polygon points="22 2 15 22 11 13 2 9 22 2"/>
          </svg>
        </button>
      </div>
    </div>
  </main>
</BaseLayout>

<style>
  .assistent-page {
    min-height: calc(100vh - 80px);
    background: linear-gradient(135deg, #f0f4f8 0%, #e2e8f0 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 20px;
  }
  .chat-container {
    width: 100%;
    max-width: 680px;
    height: calc(100vh - 140px);
    max-height: 800px;
    background: white;
    border-radius: 20px;
    box-shadow: 0 8px 40px rgba(0, 51, 102, 0.12);
    border: 1px solid rgba(0, 51, 102, 0.08);
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }
  .chat-header {
    padding: 18px 24px;
    border-bottom: 1px solid rgba(0, 51, 102, 0.08);
    background: linear-gradient(135deg, #f8fafc, #fff);
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .chat-header-left { display: flex; align-items: center; gap: 12px; }
  .chat-title { font-size: 15px; font-weight: 700; color: #003366; }
  .chat-status { font-size: 12px; font-weight: 500; }
  .chat-status.online { color: #22c55e; }
  .chat-status.offline { color: #ef4444; }
  .chat-status.checking { color: #f59e0b; }
  .chat-messages {
    flex: 1;
    overflow-y: auto;
    padding: 20px 24px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .chat-messages::-webkit-scrollbar { width: 5px; }
  .chat-messages::-webkit-scrollbar-thumb { background: rgba(0, 51, 102, 0.15); border-radius: 3px; }
  .msg { display: flex; gap: 10px; max-width: 85%; animation: msg-in 0.25s ease; }
  @keyframes msg-in { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }
  .msg-bot { align-self: flex-start; }
  .msg-user { align-self: flex-end; flex-direction: row-reverse; }
  .msg-avatar {
    width: 32px; height: 32px; border-radius: 50%;
    background: #f1f4f9;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }
  .msg-user .msg-avatar { background: #003366; color: white; font-size: 14px; font-weight: 700; }
  .msg-content { padding: 10px 14px; border-radius: 14px; font-size: 14px; line-height: 1.5; }
  .msg-bot .msg-content { background: #f1f4f9; color: #1e293b; border-bottom-left-radius: 4px; }
  .msg-user .msg-content { background: #003366; color: white; border-bottom-right-radius: 4px; }
  .msg-text { white-space: pre-wrap; word-wrap: break-word; }
  .msg-text.streaming::after { content: '▊'; animation: blink 0.6s infinite; }
  @keyframes blink { 0%, 100% { opacity: 0; } 50% { opacity: 1; } }
  .msg-error .msg-content { background: #fef2f2; color: #dc2626; border: 1px solid #fecaca; }
  .chat-typing { display: none; gap: 5px; padding: 0 24px 12px; }
  .chat-typing.active { display: flex; }
  .typing-dot {
    width: 10px; height: 10px; background: #94a3b8;
    border-radius: 50%; animation: bounce 1.4s infinite ease-in-out;
  }
  .typing-dot:nth-child(2) { animation-delay: 0.16s; }
  .typing-dot:nth-child(3) { animation-delay: 0.32s; }
  @keyframes bounce {
    0%,60%,100% { transform: translateY(0); opacity: 0.3; }
    30% { transform: translateY(-10px); opacity: 0.8; }
  }
  .chat-input-row {
    display: flex; gap: 10px;
    padding: 16px 24px;
    border-top: 1px solid rgba(0, 51, 102, 0.08);
    background: #fafbfc;
    flex-shrink: 0;
  }
  .chat-input {
    flex: 1; border: 1px solid #d1d9e6; border-radius: 12px;
    padding: 12px 16px; font-size: 14px; font-family: inherit;
    resize: none; outline: none; background: white;
    min-height: 44px; max-height: 120px; transition: border-color 0.2s;
  }
  .chat-input:focus { border-color: #004a99; box-shadow: 0 0 0 3px rgba(0, 74, 153, 0.1); }
  .chat-send {
    width: 44px; height: 44px; border: none; border-radius: 12px;
    background: #003366; color: white; cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0; transition: all 0.15s;
    box-shadow: 0 2px 8px rgba(0, 51, 102, 0.2);
  }
  .chat-send:hover { transform: translateY(-1px); box-shadow: 0 4px 12px rgba(0, 51, 102, 0.3); }
  .chat-send:disabled { opacity: 0.5; cursor: not-allowed; transform: none; }
  @media (max-width: 640px) {
    .assistent-page { padding: 8px; }
    .chat-container { height: calc(100vh - 96px); max-height: none; border-radius: 12px; }
    .chat-messages { padding: 16px; }
    .chat-input-row { padding: 12px 16px; }
    .msg { max-width: 92%; }
  }
</style>

<script>
(function() {
  const input = document.getElementById('chat-input');
  const sendBtn = document.getElementById('chat-send');
  const messages = document.getElementById('chat-messages');
  const typing = document.getElementById('chat-typing');
  const statusEl = document.getElementById('chat-status');
  let isLoading = false;
  let history = [];

  async function checkStatus() {
    statusEl.textContent = 'Controleren...';
    statusEl.className = 'chat-status checking';
    try {
      const res = await fetch('/api/ollama-chat', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ message: 'ping', history: [] })
      });
      if (res.ok) { statusEl.textContent = 'Online'; statusEl.className = 'chat-status online'; }
      else { statusEl.textContent = 'Offline'; statusEl.className = 'chat-status offline'; }
    } catch {
      statusEl.textContent = 'Offline';
      statusEl.className = 'chat-status offline';
    }
  }
  checkStatus();

  input.addEventListener('input', function() {
    this.style.height = 'auto';
    this.style.height = Math.min(this.scrollHeight, 120) + 'px';
  });
  input.addEventListener('keydown', function(e) {
    if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); send(); }
  });
  sendBtn.addEventListener('click', send);

  function escapeHtml(s) {
    const d = document.createElement('div');
    d.textContent = s;
    return d.innerHTML;
  }

  function addMsg(text, type) {
    const div = document.createElement('div');
    div.className = 'msg msg-' + type;
    const isUser = type === 'user';
    div.innerHTML = isUser
      ? '<div class="msg-avatar">' + (localStorage.getItem('ha-initial') || 'J') + '</div>'
      : '<div class="msg-avatar"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#C5A059" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a7 7 0 0 0-7 7c0 5.25 7 13 7 13s7-7.75 7-13a7 7 0 0 0-7-7z"/><circle cx="12" cy="9" r="2.5"/></svg></div>';
    const contentDiv = document.createElement('div');
    contentDiv.className = 'msg-content';
    const textDiv = document.createElement('div');
    textDiv.className = 'msg-text';
    textDiv.textContent = text;
    contentDiv.appendChild(textDiv);
    div.appendChild(contentDiv);
    messages.appendChild(div);
    messages.scrollTop = messages.scrollHeight;
    return textDiv;
  }

  function addBronLinks(resultaten) {
    if (!resultaten || resultaten.length === 0) return null;
    const forums = resultaten.filter(r => r.type === 'forum' || r.type === 'artikel');
    const winkels = resultaten.filter(r => r.type === 'winkel');
    if (forums.length === 0 && winkels.length === 0) return null;

    const linksDiv = document.createElement('div');
    linksDiv.style.cssText = 'margin-top:10px;padding-top:10px;border-top:1px solid rgba(0,0,0,0.08);';

    function addBronLinksGroup(bronnen, label, color, typeLabel) {
      if (bronnen.length === 0) return;
      const lbl = document.createElement('div');
      lbl.style.cssText = 'font-size:11px;font-weight:600;color:' + color + ';margin:8px 0 6px;text-transform:uppercase;letter-spacing:0.05em;';
      lbl.textContent = label;
      linksDiv.appendChild(lbl);
      bronnen.forEach(function(r) {
        const a = document.createElement('a');
        a.href = r.url;
        a.target = '_blank';
        a.rel = 'noopener';
        a.style.cssText = 'display:block;padding:6px 10px;margin:2px 0;border-radius:6px;font-size:12px;color:' + color + ';font-weight:500;text-decoration:none;background:rgba(0,0,0,0.04);transition:background 0.15s;';
        a.onmouseover = function() { this.style.background = 'rgba(0,0,0,0.08)'; };
        a.onmouseout = function() { this.style.background = 'rgba(0,0,0,0.04)'; };
        a.innerHTML = '<span style="font-size:10px;color:#94a3b8;font-weight:600;margin-right:6px;">[' + typeLabel + ']</span> <span style="font-size:10px;color:' + color + ';font-weight:600;margin-right:6px;">' + r.bron + '</span>' + r.title;
        linksDiv.appendChild(a);
      });
    }
    addBronLinksGroup(forums, 'Informatie:', '#7c3aed', 'INFO');
    addBronLinksGroup(winkels, 'Webshops:', '#004A99', 'WINKEL');
    return linksDiv;
  }

  function showTyping() { typing.classList.add('active'); sendBtn.disabled = true; isLoading = true; }
  function hideTyping() { typing.classList.remove('active'); sendBtn.disabled = false; isLoading = false; }

  async function send() {
    const text = input.value.trim();
    if (!text || isLoading) return;

    addMsg(text, 'user');
    history.push({ role: 'user', content: text });
    input.value = '';
    input.style.height = 'auto';
    showTyping();
    localStorage.setItem('ha-initial', text.charAt(0).toUpperCase());

    const botDiv = document.createElement('div');
    botDiv.className = 'msg msg-bot';
    botDiv.innerHTML = '<div class="msg-avatar"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#C5A059" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a7 7 0 0 0-7 7c0 5.25 7 13 7 13s7-7.75 7-13a7 7 0 0 0-7-7z"/><circle cx="12" cy="9" r="2.5"/></svg></div>';
    const contentDiv = document.createElement('div');
    contentDiv.className = 'msg-content';
    const textDiv = document.createElement('div');
    textDiv.className = 'msg-text streaming';
    textDiv.textContent = '';
    contentDiv.appendChild(textDiv);
    botDiv.appendChild(contentDiv);
    messages.appendChild(botDiv);
    hideTyping();

    let reply = '';
    let zoekResultaten = null;

    try {
      const controller = new AbortController();
      const timeoutId = setTimeout(() => controller.abort(), 65000);
      const res = await fetch('/api/ollama-chat', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ message: text, history }),
        signal: controller.signal
      });
      clearTimeout(timeoutId);

      if (!res.ok) {
        const errData = await res.json().catch(() => ({}));
        throw new Error(errData.error || 'Fout bij verbinding');
      }

      const reader = res.body.getReader();
      const decoder = new TextDecoder();
      let buffer = '';

      while (true) {
        const { done, value } = await reader.read();
        if (done) break;
        buffer += decoder.decode(value, { stream: true });
        const lines = buffer.split('\n');
        buffer = lines.pop() || '';

        for (const line of lines) {
          if (!line.trim()) continue;
          try {
            const parsed = JSON.parse(line);
            if (parsed.type === 'zoek') {
              zoekResultaten = parsed.resultaten;
            } else if (parsed.type === 'token') {
              reply += parsed.text;
              textDiv.textContent = reply;
              messages.scrollTop = messages.scrollHeight;
            } else if (parsed.type === 'error') {
              reply += '\n(Fout bij streamen)';
              textDiv.textContent = reply;
            }
          } catch {}
        }
      }

      textDiv.classList.remove('streaming');
      history.push({ role: 'assistant', content: reply });

      if (zoekResultaten) {
        const linksEl = addBronLinks(zoekResultaten);
        if (linksEl) contentDiv.appendChild(linksEl);
      }
      messages.scrollTop = messages.scrollHeight;
    } catch (e) {
      textDiv.classList.remove('streaming');
      textDiv.textContent = e.name === 'AbortError'
        ? 'De assistent reageert niet. Probeer het opnieuw.'
        : 'Fout: geen verbinding met de assistent.';
      botDiv.classList.add('msg-error');
      messages.scrollTop = messages.scrollHeight;
    }
  }
})();
</script>
