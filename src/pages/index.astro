---
import BaseLayout from '../layouts/BaseLayout.astro';
import KVVI3DLogo from '../components/KVVI3DLogo.astro';
import ImageCarousel from '../components/ImageCarousel.astro';
import WedstrijdTabel from '../components/WedstrijdTabel.astro';
import WedstrijdKalender from '../components/WedstrijdKalender.astro';
import fs from 'node:fs';
import path from 'node:path';

const photosPath = path.resolve('./public/Fotos Home');
const homeDir = path.resolve('./public/Fotos Home');
const extraDir = path.resolve('./public/Foto Fotos');

let visibleImages = [];
try {
  const photoFiles = fs.readdirSync(photosPath)
    .filter(file => file.endsWith('.png') || file.endsWith('.jpg') || file.endsWith('.jpeg'))
    .filter(file => !file.includes('_640.'))
    .sort();
  const seen = new Set();
  
  visibleImages = photoFiles.map(file => `/Fotos Home/${encodeURIComponent(file)}`);
  // 1. Laad uit Fotos Home
  if (fs.existsSync(homeDir)) {
    fs.readdirSync(homeDir).forEach(f => {
      if (/\.(png|jpe?g|webp|gif)$/i.test(f) && !f.includes('_640.')) {
        seen.add(f.toLowerCase());
        visibleImages.push(`/Fotos Home/${encodeURIComponent(f)}`);
      }
    });
  }
  
  // 2. Laad uit Foto Fotos (zonder dubbelen)
  if (fs.existsSync(extraDir)) {
    fs.readdirSync(extraDir).forEach(f => {
      if (/\.(png|jpe?g|webp|gif)$/i.test(f) && !f.includes('_640.') && !seen.has(f.toLowerCase())) {
        visibleImages.push(`/Foto Fotos/${encodeURIComponent(f)}`);
      }
    });
  }

  visibleImages.sort();
} catch (error) {
  console.error('Error loading photos:', error);
  visibleImages = [];
}
---

<BaseLayout title="Home" description="KVVI — Koninklijke Vrije Vissers Izegem. Ontdek viswedstrijden, uitslagen, de hengelkaart en meer voor vissers in West-Vlaanderen.">
  <!-- Hero Section -->
  <header class="relative bg-gradient-to-br from-[#004A99] to-[#002b59] py-12 md:py-32 overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 relative z-10 flex flex-col md:flex-row items-center justify-between gap-6 md:gap-8">
      <div class="flex-1 text-center md:text-left text-white">
        <h1 class="text-4xl md:text-6xl font-black italic mb-4 tracking-tighter leading-none uppercase">
          KVVI<br />
          <span class="text-[#D4AF37]">Izegem</span>
        </h1>
        <h2 class="text-xl md:text-2xl font-bold text-blue-100 mb-6 md:mb-8 uppercase tracking-widest">
          Koninklijke Vrije Vissers
        </h2>
        <p class="text-blue-50 text-lg md:text-xl leading-relaxed mb-8 md:mb-10 max-w-lg">
          De digitale thuisbasis van de Koninklijke Vrije Vissers Izegem. Al sinds jaar en dag het epicentrum van wedstrijdvissen in Izegem.
        </p>
        <div class="flex flex-wrap justify-center md:justify-start gap-3 md:gap-4">
          <a href="/uitslagen/Zaterdagvissers" class="bg-[#D4AF37] text-[#004A99] px-6 md:px-10 py-3 md:py-4 rounded-lg font-black uppercase tracking-widest hover:bg-white transition-all shadow-2xl text-sm">
            → Uitslagen
          </a>
          <a href="/hengelmap" class="bg-white/20 text-white px-6 md:px-10 py-3 md:py-4 rounded-lg font-bold uppercase tracking-widest hover:bg-white/30 transition-all border border-white/50 text-sm">
            🗺️ Hengelmap
          </a>
        </div>
      </div>
      
      <div class="w-48 h-48 md:w-80 md:h-80 lg:w-96 lg:h-96">
        <KVVI3DLogo />
      </div>
    </div>
  </header>

  <!-- Wedstrijdkalender 2026 -->
  <section class="py-12 bg-slate-50">
    <div class="max-w-4xl mx-auto px-4">
      <WedstrijdKalender />
    </div>
  </section>

  <!-- Over KVVI -->
  <section class="py-16 bg-white">
    <div class="max-w-6xl mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-4xl font-black text-[#004A99] mb-8 uppercase tracking-tight text-center">
          Over KVVI
        </h2>
        <p class="text-lg text-slate-700 mb-6 leading-relaxed text-center">
          De Koninklijke Vrije Vissers Izegem is een actieve visserij club gevestigd aan <strong>De Plataan</strong> in Izegem, West-Vlaanderen.
        </p>
        <p class="text-lg text-slate-700 mb-8 leading-relaxed text-center">
          Wij organiseren regelmatige wedstrijdvisseries en behoren tot de meest actieve clubs in de regio. Onze leden staan bekend om hun passie voor de hengelsport en hun gezelligheid.
        </p>
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <div class="text-center">
            <span class="text-3xl">🎣</span>
            <h4 class="font-bold text-slate-800 mt-2">Wedstrijdvissen</h4>
            <p class="text-slate-600 text-sm">Zaterdagvissers en Veteranen groepen</p>
          </div>
          <div class="text-center">
            <span class="text-3xl">📍</span>
            <h4 class="font-bold text-slate-800 mt-2">Vistekken</h4>
            <p class="text-slate-600 text-sm">De beste locaties in Vlaanderen</p>
          </div>
          <div class="text-center">
            <span class="text-3xl">🏆</span>
            <h4 class="font-bold text-slate-800 mt-2">Traditie</h4>
            <p class="text-slate-600 text-sm">Jarenlange passie voor de sport</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Snelle Toegang -->
  <section class="py-16 bg-slate-50">
    <div class="max-w-6xl mx-auto px-4">
      <h2 class="text-4xl font-black text-[#004A99] mb-8 uppercase tracking-tight text-center">
        Snel Toegang
      </h2>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <a href="/uitslagen/Zaterdagvissers" class="bg-white rounded-xl shadow-sm border border-slate-200 p-8 hover:shadow-lg hover:border-[#D4AF37] transition-all group">
          <div class="text-4xl mb-4">🏆</div>
          <h3 class="text-xl font-bold text-[#004A99] mb-2 group-hover:text-[#D4AF37]">Zaterdagvissers</h3>
          <p class="text-slate-600 text-sm mb-4">Bekijk de uitslagen en rangschikking van de Zaterdagvissers wedstrijden.</p>
          <span class="text-[#D4AF37] font-bold text-sm">→ Bekijk uitslagen</span>
        </a>

        <a href="/uitslagen/Veteranen" class="bg-white rounded-xl shadow-sm border border-slate-200 p-8 hover:shadow-lg hover:border-[#D4AF37] transition-all group">
          <div class="text-4xl mb-4">👴</div>
          <h3 class="text-xl font-bold text-[#004A99] mb-2 group-hover:text-[#D4AF37]">Veteranen</h3>
          <p class="text-slate-600 text-sm mb-4">Bekijk de uitslagen van de Veteranen wedstrijden en hun statistieken.</p>
          <span class="text-[#D4AF37] font-bold text-sm">→ Bekijk uitslagen</span>
        </a>

        <a href="/hengelmap" class="bg-white rounded-xl shadow-sm border border-slate-200 p-8 hover:shadow-lg hover:border-[#D4AF37] transition-all group">
          <div class="text-4xl mb-4">🗺️</div>
          <h3 class="text-xl font-bold text-[#004A99] mb-2 group-hover:text-[#D4AF37]">Hengelmap</h3>
          <p class="text-slate-600 text-sm mb-4">Ontdek alle vistekken op onze interactieve kaart van Vlaanderen.</p>
          <span class="text-[#D4AF37] font-bold text-sm">→ Bekijk kaart</span>
        </a>
      </div>
    </div>
  </section>

  
  
  <!-- Gallerij -->
  <section class="py-20 bg-slate-100">
    <div class="max-w-6xl mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="text-4xl font-black text-[#004A99] uppercase tracking-tight mb-4">
            Foto's & Momenten
          </h2>
          <p class="mt-4 text-slate-600 max-w-2xl mx-auto">
            Een selectie van sfeerbeelden van onze visstekken en evenementen. Swipe of klik verder om meer te bekijken.
          </p>
      </div>

      {visibleImages.length > 0 ? (
        <ImageCarousel 
          images={visibleImages}
          interval={5500}
        />
      ) : (
        <div class="rounded-3xl border border-slate-200 bg-white p-16 text-center text-slate-500">
          Geen zichtbare foto's gevonden. Voeg foto's toe in de map /public/Fotos Home of /public/Foto Fotos.
        </div>
      )}
    </div>
  </section>

  <!-- Contact & Info -->
  <section class="py-20 bg-white">
    <div class="max-w-6xl mx-auto px-4">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
        <div>
          <h2 class="text-3xl font-black text-[#004A99] mb-6 uppercase tracking-tight">
            Contact
          </h2>
          <div class="space-y-4">
            <div class="flex items-start gap-4">
              <span class="text-2xl">📍</span>
              <div>
                <h4 class="font-bold text-slate-800">Locatie</h4>
                <p class="text-slate-600">De Plataan, <br>Vijverhof, Izegem<br>West-Vlaanderen, België</p>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <span class="text-2xl">📧</span>
              <div>
                <h4 class="font-bold text-slate-800">Contact</h4>
                <p class="text-slate-600">Via de contactpagina op deze website</p>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <span class="text-2xl">🎥</span>
              <div>
                <h4 class="font-bold text-slate-800">YouTube</h4>
                <a href="https://www.youtube.com/channel/UCaJPBFS9goMeW0IRtR8J2ug" target="_blank" rel="noopener noreferrer" class="text-[#004A99] font-semibold hover:text-[#D4AF37]">
                  KVVI Izegem Kanaal →
                </a>
              </div>
            </div>
          </div>
        </div>

        <div>
          <h2 class="text-3xl font-black text-[#004A99] mb-6 uppercase tracking-tight">
            Volgen
          </h2>
          <p class="text-slate-700 mb-6">
            Volg KVVI op social media voor updates, foto's en wedstrijdverslagen.
          </p>
          <div class="flex gap-4">
            <a href="https://www.facebook.com" target="_blank" rel="noopener noreferrer" class="w-12 h-12 bg-[#004A99] text-white rounded-lg flex items-center justify-center hover:bg-[#D4AF37] transition-all text-xl font-bold">
              f
            </a>
            <a href="https://www.youtube.com/channel/UCaJPBFS9goMeW0IRtR8J2ug" target="_blank" rel="noopener noreferrer" class="w-12 h-12 bg-red-600 text-white rounded-lg flex items-center justify-center hover:bg-red-700 transition-all text-xl font-bold">
              ▶
            </a>
            <a href="/hengelmap" class="w-12 h-12 bg-green-600 text-white rounded-lg flex items-center justify-center hover:bg-green-700 transition-all text-xl font-bold">
              🗺
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-16 bg-[#004A99] text-white text-center">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="text-3xl md:text-4xl font-black mb-6 uppercase tracking-tight">
        Klaar om meer te ontdekken?
      </h2>
      <p class="text-xl text-blue-100 mb-8">
        Bekijk de uitslagen, vistekken, en meer informatie over onze club.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="/hengelmap" class="bg-white/20 text-white px-8 py-4 rounded-lg font-bold uppercase tracking-widest hover:bg-white/30 transition-all border border-white/50 text-sm">
          Kaart Bekijken
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  :global(html) {
    scroll-behavior: smooth;
  }
</style>