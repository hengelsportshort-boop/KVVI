.flex { display: flex; gap: 8px; align-items: center; flex-wrap: wrap; }
.mt-2 { margin-top: 8px; }
.mb-2 { margin-bottom: 8px; }
.w-full { width: 100%; }
table { width: 100%; border-collapse: collapse; font-size: 12px; }
