function updateVsDuur() {
  const begin = document.getElementById('vs-begin').value;
  const einde = document.getElementById('vs-einde').value;
  const d = calcDuurVanBeginEinde(begin, einde);
  const container = document.getElementById('vs-duur-container');
  const el = document.getElementById('vs-duur');
  if (d != null) {
    el.textContent = fmtTime(d);
    container.style.display = '';
  } else {
    el.textContent = '--';
    container.style.display = 'none';
  }
}
