function fmtBeginEinde(val) {
  if (!val || val.length < 3) return '';
  const s = val.padStart(4, '0');
  return s.substring(0, 2) + 'u ' + s.substring(2, 4) + 'm';
}
['vs-begin','vs-einde'].forEach(id => {
  document.getElementById(id).addEventListener('input', function() {
    if (this.value.length > 4) this.value = this.value.slice(0, 4);
    const display = document.getElementById(id + '-display');
    if (display) display.textContent = fmtBeginEinde(this.value) || '';
  });
});
function vsGewichtGram() {
  const k = parseInt(document.getElementById('vs-kroes').value) || 0;
  const s = parseInt(document.getElementById('vs-schub').value) || 0;
  const p = parseInt(document.getElementById('vs-spiegel').value) || 0;
  const a = parseInt(document.getElementById('vs-ander').value) || 0;
  return k * GEW_KROES + s * GEW_SCHUB + p * GEW_SPIEGEL + a * GEW_ANDER;
}

function fmtKg(gram) {
  return (gram / 1000).toLocaleString('nl-NL', { minimumFractionDigits: 3, maximumFractionDigits: 3 }) + ' kg';
}

function vsAdjust(id, delta, maxVal) {
  const el = document.getElementById(id);
  let v = parseInt(el.value) || 0;
  v = Math.max(0, Math.min(maxVal || 999, v + delta));
  el.value = String(v).padStart(3, '0');
  updateVsAantal();
}
function updateVsAantal() {
  const ids = ['vs-kroes','vs-schub','vs-spiegel','vs-ander'];
  const sum = ids.reduce((a, id) => a + (parseInt(document.getElementById(id).value) || 0), 0);
  const elAantal = document.getElementById('vs-aantal');
  if (elAantal) elAantal.textContent = sum;
  const elGewicht = document.getElementById('vs-gewicht');
  const gram = vsGewichtGram();
  if (elGewicht) {
    elGewicht.textContent = (gram / 1000).toLocaleString('nl-NL', { minimumFractionDigits: 3, maximumFractionDigits: 3 });
    elGewicht.setAttribute('data-gram', String(gram));
  }
}
['vs-kroes','vs-schub','vs-spiegel','vs-ander'].forEach(id => {
  document.getElementById(id).addEventListener('input', function() {
    this.value = this.value.replace(/[^0-9]/g, '').slice(0, 3);
    const v = parseInt(this.value);
    if (v > 999) this.value = '999';
    updateVsAantal();
  });
  document.getElementById(id).addEventListener('blur', function() {
    if (this.value === '') this.value = '0';
    this.value = String(parseInt(this.value) || 0).padStart(3, '0');
    updateVsAantal();
  });
});

document.getElementById('vs-datum').addEventListener('input', () => {
  const stek = document.getElementById('vs-stek').value.trim().toLowerCase();
  const datum = document.getElementById('vs-datum').value.trim();
  if (!stek || !datum) return;
  const jaar = huidigJaar();
  const month = deriveMonth(datum, jaar);
  const data = loadData();
  const bestaand = data.find(r => r.datum === datum && r.month === month && r.stek && r.stek.toLowerCase() === stek);
  if (!bestaand) return;
  document.getElementById('vs-kroes').value = String(bestaand.kroes || 0).padStart(3, '0');
  document.getElementById('vs-schub').value = String(bestaand.schub || 0).padStart(3, '0');
  document.getElementById('vs-spiegel').value = String(bestaand.spiegel || 0).padStart(3, '0');
  document.getElementById('vs-ander').value = String(bestaand.ander || 0).padStart(3, '0');
  document.getElementById('vs-begin').value = bestaand.begin || '';
  document.getElementById('vs-einde').value = bestaand.einde || '';
  updateVsAantal();
});
function renderVisstekList() {
  const stek = document.getElementById('vs-stek').value.trim().toLowerCase();
  const el = document.getElementById('vs-list');
  const data = loadData();
  const stekDates = [...new Set(data.filter(r => r.stek && r.stek.toLowerCase() === stek).map(r => r.datum).filter(Boolean))];
  document.getElementById('vs-datum-list').innerHTML = stekDates.map(d => `<option value="${d}">`).join('');
  if (!stek) { el.innerHTML = '<p class="empty-msg">Voer een stek in om eerdere sessies te zien.</p>'; return; }
  const filtered = data.filter(r => r.stek && r.stek.toLowerCase() === stek);
  if (!filtered.length) { el.innerHTML = '<p class="empty-msg">Geen sessies voor deze stek.</p>'; return; }
  const computed = filtered.map(r => computeFields(r)).sort((a, b) => {
    function dv(r) { const p = r.datum ? r.datum.split('/') : []; return p.length === 2 ? parseInt(p[1]) * 100 + parseInt(p[0]) : 99999; }
    return dv(b) - dv(a);
  });
  let html = `<table><thead><tr style="text-align:center"><th>Datum</th><th>Kroes</th><th>Schub</th><th>Spiegel</th><th>Ander</th><th>Aantal</th><th>Begin</th><th>Einde</th><th>Duur</th></tr></thead><tbody>`;
  for (const c of computed) {
    html += `<tr style="text-align:center"><td>${c.datum}</td><td class="num">${c.kroes || ''}</td><td class="num">${c.schub || ''}</td><td class="num">${c.spiegel || ''}</td><td class="num">${c.ander || ''}</td><td class="num">${c.aantal}</td><td>${c.begin}</td><td>${c.einde}</td><td class="num">${fmtTime(c.duurMin)}</td></tr>`;
  }
  const t = computed.reduce((a, r) => ({ kroes: a.kroes + r.kroes, schub: a.schub + r.schub, spiegel: a.spiegel + r.spiegel, ander: a.ander + r.ander, aantal: a.aantal + r.aantal }), { kroes: 0, schub: 0, spiegel: 0, ander: 0, aantal: 0 });
  html += `<tr class="subtotal" style="text-align:center"><td>TOTAAL</td><td class="num">${t.kroes}</td><td class="num">${t.schub}</td><td class="num">${t.spiegel}</td><td class="num">${t.ander}</td><td class="num">${t.aantal}</td><td colspan="3">${filtered.length} sessies</td></tr></tbody></table>`;
  el.innerHTML = html;
}
document.getElementById('vs-stek').addEventListener('input', renderVisstekList);

