function backupStatus(msg, isError) {
  const el = document.getElementById('backup-status');
  el.textContent = msg;
  el.style.color = isError ? '#dc2626' : '#166534';
}

function downloadLocalBackup() {
  const data = loadData();
  const json = JSON.stringify(data, null, 2);
  const blob = new Blob([json], { type: 'application/json' });
  const a = document.createElement('a');
  const ts = new Date().toISOString().slice(0, 10);
  a.href = URL.createObjectURL(blob);
  a.download = 'kvvi-vissessies-' + ts + '.json';
  a.click();
  URL.revokeObjectURL(a.href);
  backupStatus('✅ ' + data.length + ' sessies gedownload als JSON');
}

document.getElementById('btn-backup-create').addEventListener('click', downloadLocalBackup);
document.getElementById('btn-backup-upload').addEventListener('click', () => {
  document.getElementById('backup-file-input').click();
});
document.getElementById('backup-file-input').addEventListener('change', async (e) => {
  const file = e.target.files[0];
  if (!file) return;
  backupStatus('🔄 Bezig met herstel...');
  try {
    const text = await file.text();
    const data = JSON.parse(text);
    if (!Array.isArray(data)) throw new Error('Bestand bevat geen geldige vissessies-data');
    saveData(data);
    render();
    backupStatus('✅ ' + data.length + ' sessies hersteld uit ' + file.name);
    showToast('✅ Data hersteld uit ' + file.name);
  } catch (e) {
    backupStatus('❌ ' + e.message, true);
  }
  e.target.value = '';
});

document.getElementById('btn-toggle-raw').addEventListener('click', () => {
  const section = document.getElementById('raw-data-section');
  const btn = document.getElementById('btn-toggle-raw');
  if (section.style.display === 'none') {
    const data = loadData();
    document.getElementById('raw-data-text').value = JSON.stringify(data, null, 2);
    section.style.display = '';
    btn.textContent = '📄 Verberg data';
  } else {
    section.style.display = 'none';
    btn.textContent = '📄 Toon data';
  }
});

document.getElementById('btn-copy-raw').addEventListener('click', () => {
  const textarea = document.getElementById('raw-data-text');
  textarea.select();
  navigator.clipboard.writeText(textarea.value).then(() => {
    showToast('📋 Data gekopieerd');
  }).catch(() => {
    document.execCommand('copy');
    showToast('📋 Data gekopieerd');
  });
});

document.getElementById('btn-paste-restore').addEventListener('click', () => {
  const textarea = document.getElementById('raw-data-text');
  textarea.readOnly = false;
  textarea.focus();
  navigator.clipboard.readText().then(text => {
    try {
      const data = JSON.parse(text);
      if (!Array.isArray(data)) throw new Error('Geen geldige data');
      if (!confirm('Data overschrijven met ' + data.length + ' sessies uit klembord?')) return;
      saveData(data);
      render();
      showToast('✅ Data hersteld uit klembord');
      backupStatus('✅ ' + data.length + ' sessies hersteld uit klembord');
      document.getElementById('raw-data-text').value = JSON.stringify(data, null, 2);
    } catch (e) {
      showToast('❌ Ongeldige JSON: ' + e.message, 'error');
    }
  }).catch(() => {
    showToast('❌ Kon niet lezen van klembord', 'error');
  }).finally(() => {
    textarea.readOnly = true;
  });
});

const SYNC_API = '/api/sync-vissessie';
function syncStatus(msg, isError) {
  const el = document.getElementById('sync-status');
  el.textContent = msg;
  el.style.color = isError ? '#dc2626' : '#166534';
}
document.getElementById('btn-sync-server').addEventListener('click', async () => {
  syncStatus('🔄 Data ophalen van server...');
  try {
    const res = await fetch(SYNC_API);
    if (res.status === 401) {
      syncStatus('❌ Niet ingelogd op admin-account', true);
      return;
    }
    if (!res.ok) throw new Error('Serverfout ' + res.status);
    const serverData = await res.json();
    if (!Array.isArray(serverData) || !serverData.length) {
      syncStatus('ℹ️ Geen data op server');
      return;
    }
    var local = loadData();
    var before = local.length;
    sortData(serverData);
    saveData(serverData);
    render();
    syncStatus('✅ Vervangen door server data (' + serverData.length + ' sessies)');
    showToast('📡 Data vervangen van server');
  } catch (e) {
    syncStatus('❌ ' + e.message, true);
  }
});

function initJaarSelector() {
  const sel = document.getElementById('year-select');
  const actief = huidigJaar();
  sel.innerHTML = jaarOpties.map(y => `<option value="${y}"${y === actief ? ' selected' : ''}>${y}</option>`).join('');
  sel.addEventListener('change', () => {
    bewaarJaar(parseInt(sel.value));
    render();
  });
}

document.querySelector('.tab[data-tab="data"]').addEventListener('click', () => {
  const sel = document.getElementById('year-select');
  const actief = huidigJaar();
  if (parseInt(sel.value) !== actief) sel.value = actief;
});
document.querySelector('.tab[data-tab="stats"]').addEventListener('click', () => {
  const sel = document.getElementById('year-select');
  const actief = huidigJaar();
  if (parseInt(sel.value) !== actief) sel.value = actief;
});

window.addEventListener('storage', function(e) {
  if (e.key === STORAGE_KEY) render();
});
// Herlaad data wanneer gebruiker terugkeert naar deze tab (bv. na Feeder Assist)
document.addEventListener('visibilitychange', function() {
  if (!document.hidden) render();
});

initJaarSelector();
render();
// Publieke app: alleen lokale data, geen sync met server
</script>
