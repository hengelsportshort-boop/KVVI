---
export const prerender = false;
import fs from 'node:fs';
import path from 'node:path';
const DATA_PATH = path.resolve('./public/data/vissessies.json');
let serverData = [];
try { serverData = JSON.parse(fs.readFileSync(DATA_PATH, 'utf-8')); } catch {}
---

<!DOCTYPE html>
<html lang="nl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1,user-scalable=no,viewport-fit=cover">
<meta name="mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="Vaste Hengel">
<link rel="apple-touch-icon" href="/vissessies-icon.svg">
<link rel="manifest" href="/manifest.json">
<title>Vaste Hengel assistent</title>
<style is:inline>
:root { --bg:#0f172a; --card:#1e293b; --text:#f1f5f9; --muted:#94a3b8; --border:#475569; --accent:#1e40af; --accent-light:#3b82f6; --danger:#ef4444; --green:#22c55e; }
* { margin:0; padding:0; box-sizing:border-box; }
html, body { height:100%; overflow:hidden; }
body { font-family:system-ui,-apple-system,sans-serif; background:var(--bg); color:var(--text); -webkit-tap-highlight-color:transparent; -webkit-user-select:none; user-select:none; touch-action:manipulation; padding:env(safe-area-inset-top) env(safe-area-inset-right) env(safe-area-inset-bottom) env(safe-area-inset-left); }
h1 { font-size:20px; margin-bottom:4px; }
.sub { color:var(--muted); font-size:13px; margin-bottom:16px; }
.tabs { display:flex; gap:6px; margin-bottom:12px; flex-wrap:wrap; }
.tab { padding:8px 18px; border-radius:8px; font-weight:600; font-size:13px; border:2px solid var(--border); background:var(--card); cursor:pointer; color:var(--text); }
.tab.active { background:var(--accent); color:#fff; border-color:var(--accent-light); }
.tab.danger { color:var(--danger); border-color:#7f1d1d; }
.panel { background:var(--card); border-radius:12px; border:1px solid var(--border); padding:16px; margin-bottom:12px; display:none; }
.panel.show { display:block; }
@media (display-mode: standalone) { .tabs { display:none !important; } }
textarea { width:100%; border:1px solid var(--border); border-radius:8px; padding:10px; font-family:monospace; font-size:12px; resize:vertical; background:var(--card); color:var(--text); }
.btn { padding:8px 18px; border-radius:8px; font-weight:600; font-size:13px; border:2px solid var(--border); cursor:pointer; -webkit-appearance:none; background:var(--card); color:var(--text); }
.btn-primary { background:var(--accent); color:#fff; border-color:var(--accent-light); }
.btn-primary:hover { background:#1e3a8a; }
.btn-danger { background:#991b1b; color:#fff; border-color:var(--danger); }
.btn-danger:hover { background:#7f1d1d; }
.btn-outline { border:2px solid var(--border); background:var(--card); }
.btn-outline:hover { background:#334155; }
.flex { display:flex; gap:8px; align-items:center; flex-wrap:wrap; }
.mt-2 { margin-top:8px; }
.mb-2 { margin-bottom:8px; }
.w-full { width:100%; }
#table-container table { width:800px; border-collapse:collapse; font-size:12px; }
th { background:#0f172a; padding:6px 4px; text-align:center !important; font-size:11px; text-transform:uppercase; color:var(--muted); border-bottom:2px solid var(--border); white-space:nowrap; }
td { padding:4px; border-bottom:1px solid #0f172a; vertical-align:top; text-align:center !important; color:var(--text); }
td[contenteditable] { cursor:text; }
td[contenteditable]:focus { outline:2px solid var(--accent-light); outline-offset:-1px; border-radius:2px; background:#334155; }
.num { font-family:monospace; }
.month-group { margin-bottom:16px; }
.month-header { background:var(--accent); color:#fff; padding:6px 10px; border-radius:6px 6px 0 0; font-weight:700; font-size:13px; display:flex; justify-content:space-between; cursor:pointer; user-select:none; }
.month-header:hover { background:#1e3a8a; }
.month-body { overflow-x:auto; overflow-y:hidden; -webkit-overflow-scrolling:touch; }
.month-body.collapsed { display:none; }
.subtotal { background:#0f172a; font-weight:700; }
.subtotal td { border-top:2px solid var(--muted); padding-top:6px; }
.grand-total { background:var(--accent); color:#fff; font-weight:700; }
.grand-total td { padding:8px 4px; }
.hidden { display:none; }
.badge { display:inline-block; padding:1px 6px; border-radius:4px; font-size:11px; font-weight:600; }
.badge-up { background:none; color:var(--green); }
.badge-down { background:none; color:var(--danger); }
tr.wedstrijd { background:#422006 !important; }
tr.wedstrijd td { border-bottom-color:#a16207; }
.empty-msg { text-align:center; color:var(--muted); padding:40px; font-style:italic; }
#toast { position:fixed; bottom:80px; left:50%; transform:translateX(-50%); padding:10px 22px; border-radius:12px; background:var(--card); color:#fff; font-weight:700; font-size:14px; opacity:0; transition:opacity 0.25s; z-index:999; pointer-events:none; white-space:nowrap; border:2px solid var(--border); box-shadow:0 4px 16px rgba(0,0,0,0.4); }
#toast.show { opacity:1; }
.sticky-header { position:sticky; top:0; z-index:100; background:var(--bg); padding:12px 20px 8px; margin:0 -16px 12px; border-bottom:1px solid var(--border); }
@media (max-width:768px) { .sticky-header { padding:10px 10px 6px; margin:0 -16px 10px; } table { font-size:11px; } td,th { padding:3px 2px; } }
.col-merk { max-width:80px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
</style>
</head>
<body>
