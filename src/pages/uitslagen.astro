---
import BaseLayout from '../layouts/BaseLayout.astro';
import TrendPijl from '../components/TrendPijl.astro';
import { laadWedstrijdData } from '../lib/csvHelper';

interface VisserData {
  naam: string;
  totaal: string;
  stand: string;
  wedstrijden: string[];
  trend?: string;
}

const jaar = String(new Date().getFullYear());
const { headers, data } = laadWedstrijdData(jaar, "Zaterdagvissers");

const naarGetal = (waarde: string | undefined | null): number => {
  if (!waarde) return 0;
  const schoon = waarde.toString().replace(' gr', '').replace(/\./g, '').replace(',', '.').trim();
  if (schoon === '--' || schoon === '') return 0;
  return parseFloat(schoon) || 0;
};

// --- LOGICA VOOR TRENDS ---
const dataMetTrend = data.map((visser: VisserData) => {
  // Maak een tijdelijke ranglijst van de vorige wedstrijd om de positie te bepalen
  const ranglijstVorigeKeer = data
    .map((v: VisserData) => ({ naam: v.naam, gewicht: naarGetal(v.wedstrijden[0]) }))
    .sort((a: { naam: string; gewicht: number }, b: { naam: string; gewicht: number }) => b.gewicht - a.gewicht);
  
  const vorigePositie = ranglijstVorigeKeer.findIndex((v: { naam: string }) => v.naam === visser.naam) + 1;

  return {
    ...visser,
    vorigeStand: vorigePositie
  };
});

const kolomTotalen: number[] = headers.map((_: string, index: number) => {
  return data.reduce((som: number, visser: VisserData) => som + naarGetal(visser.wedstrijden[index]), 0);
});

const algemeenTotaal = kolomTotalen.reduce((a: number, b: number) => a + b, 0);
const formatteer = (getal: number): string => getal.toLocaleString('nl-BE');

const getRankClass = (rank: string): string => {
  if (rank === "1") return "bg-yellow-100 text-yellow-800 border-yellow-200 shadow-[0_2px_10px_rgba(234,179,8,0.2)]";
  if (rank === "2") return "bg-slate-200 text-slate-700 border-slate-300";
  if (rank === "3") return "bg-orange-100 text-orange-800 border-orange-200";
  return "bg-slate-50 text-slate-500 border-slate-200";
};
---

<BaseLayout title="Wedstrijduitslagen" description="Alle viswedstrijd uitslagen van KVVI Izegem — Zaterdagvissers, Veteranen en speciale wedstrijden.">
  <div class="max-w-[98%] mx-auto py-4 md:py-8 font-sans">
    
    <header class="flex flex-col md:flex-row justify-between items-start md:items-end mb-8 border-b-4 border-[#004A99] pb-6 gap-4">
      <div>
        <h1 class="text-3xl md:text-5xl font-black text-[#004A99] tracking-tight italic">
          Zaterdagvissers <span class="text-[#D4AF37]">{jaar}</span>
        </h1>
        <p class="text-slate-500 text-sm md:text-lg font-bold uppercase tracking-widest">
          Koninklijke Vrije Vissers Izegem
        </p>
      </div>
      <div class="bg-gradient-to-br from-[#1E3D2C] to-[#2d5a41] p-5 rounded-2xl shadow-xl w-full md:w-auto border-b-4 border-black/20 transform hover:scale-105 transition-transform text-right">
        <div class="text-[10px] uppercase tracking-widest text-green-200/70 font-black mb-1">Totaal Gewicht Club</div>
        <div class="text-2xl md:text-4xl font-mono font-black text-white">
          {formatteer(algemeenTotaal)} <span class="text-xs text-green-300 font-sans uppercase">gr</span>
        </div>
      </div>
    </header>

    <div class="block md:hidden space-y-6">
      {dataMetTrend.map((visser: VisserData & { vorigeStand: number }) => (
        <div class="bg-white border-l-8 border-[#004A99] rounded-2xl shadow-md overflow-hidden">
          <div class="p-4">
            <div class="flex justify-between items-center mb-4">
              <span class={`font-black px-4 py-1 rounded-full text-xs border ${getRankClass(visser.stand)}`}>
                POS {visser.stand}
              </span>
              <span class="text-[#1E3D2C] font-black text-xl bg-green-50 px-3 py-1 rounded-lg border border-green-100">
                {visser.totaal} <span class="text-[10px] font-normal uppercase font-sans">gr</span>
              </span>
            </div>
            <h3 class="text-xl font-black text-slate-800 mb-4 border-b pb-2 tracking-tight">{visser.naam}</h3>
            
            <div class="grid grid-cols-3 gap-2">
              {headers.map((h: string, i: number) => (
                <div class="text-center p-2 bg-slate-50 rounded-xl border border-slate-100">
                  <div class="text-[9px] text-[#004A99] font-bold uppercase mb-1 opacity-70">{h}</div>
                  <div class="text-xs font-mono font-bold text-slate-700">
                    {naarGetal(visser.wedstrijden[i]) > 0 ? visser.wedstrijden[i] : <span class="text-slate-300">0</span>}
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>

    <div class="hidden md:block bg-white rounded-3xl shadow-2xl border border-slate-200 overflow-hidden text-black">
      <div class="max-w-7xl mx-auto">
        <div class="overflow-x-auto touch-pan-x">
          <table class="w-full text-sm border-collapse min-w-[1100px] max-w-full">
          <thead>
            <tr class="bg-[#004A99] text-white">
              <th class="px-4 py-6 font-black w-16 text-center uppercase tracking-tighter">Pos</th>
              <th class="px-4 py-6 font-black w-14 text-center uppercase tracking-tighter border-l border-blue-400/30">Trend</th>
              <th class="px-6 py-6 font-black min-w-[220px] sticky left-0 bg-[#004A99] z-20 text-left uppercase tracking-tight">Visser</th>
              {headers.map((h: string) => (
                <th class="px-2 py-6 font-bold text-center text-[11px] uppercase tracking-tighter text-blue-100 border-l border-blue-400/20">{h}</th>
              ))}
              <th class="px-8 py-6 font-black text-right bg-[#003366] sticky right-0 z-20 uppercase tracking-tight shadow-[-5px_0_15px_rgba(0,0,0,0.1)]">Totaal</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100">
            {dataMetTrend.map((visser: VisserData & { vorigeStand: number }, index: number) => (
              <tr class={index % 2 === 0 ? "bg-white" : "bg-blue-50/20 hover:bg-blue-100/30 transition-colors"}>
                <td class="px-4 py-5 text-center">
                   <span class={`inline-flex items-center justify-center w-9 h-9 rounded-full font-black text-sm border ${getRankClass(visser.stand)}`}>
                    {visser.stand}
                   </span>
                </td>
                <td class="px-4 py-5 border-l border-slate-100/50">
                  <TrendPijl huidigeStand={parseInt(visser.stand)} vorigeStand={visser.vorigeStand} /> </td>
                <td class={`px-6 py-5 font-bold text-slate-800 sticky left-0 z-10 border-r shadow-[5px_0_10px_rgba(0,0,0,0.02)] ${index % 2 === 0 ? "bg-white" : "bg-[#f8faff]"}`}>
                  {visser.naam}
                </td>
                {visser.wedstrijden.map((g: string) => (
                  <td class="px-2 py-5 text-center text-slate-600 font-mono text-xs border-r border-slate-50/50">
                    {naarGetal(g) > 0 ? g : <span class="opacity-20 font-sans">0</span>}
                  </td>
                ))}
                <td class="px-8 py-5 text-right font-black text-[#1E3D2C] bg-green-50/60 sticky right-0 border-l border-green-100/50 backdrop-blur-md italic font-mono text-base">
                  {visser.totaal} <span class="text-[10px] font-sans font-bold uppercase not-italic ml-1">gr</span>
                </td>
              </tr>
            ))}
          </tbody>
          <tfoot class="sticky bottom-0 z-30">
            <tr class="bg-slate-900 text-white font-bold border-t-4 border-black">
              <td colspan="3" class="px-6 py-6 text-right uppercase text-[11px] font-black tracking-[0.2em] text-blue-300 sticky left-0 bg-slate-900">
                Totaal Dagvangst:
              </td>
              {kolomTotalen.map((t: number) => (
                <td class="px-2 py-6 text-center font-mono text-xs border-x border-slate-800/50">
                  {t > 0 ? formatteer(t) : <span class="opacity-30">0</span>}
                </td>
              ))}
              <td class="px-8 py-6 text-right font-black bg-[#D4AF37] text-[#004A99] sticky right-0 shadow-[0_-10px_20px_rgba(0,0,0,0.2)] text-lg">
                {formatteer(algemeenTotaal)} <span class="text-[10px] font-sans font-black uppercase">gr</span>
              </td>
            </tr>
          </tfoot>
        </table>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>