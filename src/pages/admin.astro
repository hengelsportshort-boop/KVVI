---
/* src/pages/admin.astro */
import Layout from '../layouts/Layout.astro';
export const prerender = false;

const pageTitle = "Admin Dashboard | KVVI";
---

<Layout title={pageTitle} noMainWrapper={true} hideNav={true}>
  <main class="h-screen flex flex-col bg-slate-50">

    <!-- MOBILE HEADER -->
    <div class="md:hidden bg-[#003366] text-white p-4 flex justify-between items-center">
      <div>
        <h1 class="text-lg font-bold tracking-widest">KVVI ADMIN</h1>
        <p class="text-[10px] text-[#C5A059] font-bold">CONTROL PANEL</p>
      </div>
      <button id="mobile-menu-btn" class="p-2 hover:bg-white/10 rounded-lg transition">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7" />
        </svg>
      </button>
    </div>

    <div class="flex flex-1 min-h-0">
      <!-- SIDEBAR -->
      <aside class="hidden md:flex w-64 bg-[#003366] text-white flex-col border-r-4 border-[#C5A059] fixed left-0 top-0 h-screen z-30">
        <div class="p-6 border-b border-white/10 hidden md:block">
          <h1 class="text-xl font-bold tracking-widest">KVVI ADMIN</h1>
          <p class="text-[10px] text-[#C5A059] font-bold">CONTROL PANEL</p>
        </div>
        
        <nav class="flex-1 p-4 space-y-1 overflow-y-auto">
          <a href="/admin" class="flex items-center gap-3 p-3 bg-white/10 rounded-lg transition-colors text-sm font-semibold">
            <span>🏠</span> Home
          </a>
          <a href="/admin/wedstrijden" class="flex items-center gap-3 p-3 hover:bg-white/5 rounded-lg transition-colors text-sm font-semibold">
            <span>🏆</span> Wedstrijden
          </a>
          <a href="/admin/kalender" class="flex items-center gap-3 p-3 hover:bg-white/5 rounded-lg transition-colors text-sm font-semibold">
            <span>📅</span> Kalender
          </a>
          <a href="/admin/visstekken" class="flex items-center gap-3 p-3 hover:bg-white/5 rounded-lg transition-colors text-sm font-semibold">
            <span>📍</span> Visstekken
          </a>
          <a href="/admin/visstekken-abc" class="flex items-center gap-3 p-3 hover:bg-white/5 rounded-lg transition-colors text-sm font-semibold">
            <span>🌐</span> ABC Visstekken
          </a>
          <a href="/admin/vissessies" class="flex items-center gap-3 p-3 hover:bg-white/5 rounded-lg transition-colors text-sm font-semibold">
            <span>📊</span> Vissessies
          </a>
          <a href="/admin/legende" class="flex items-center gap-3 p-3 hover:bg-white/5 rounded-lg transition-colors text-sm font-semibold">
            <span>📖</span> Legende
          </a>
          <a href="/admin/hengelshop" class="flex items-center gap-3 p-3 hover:bg-white/5 rounded-lg transition-colors text-sm font-semibold">
            <span>📦</span> Hengelshop
          </a>
          <a href="/admin/koppelwedstrijden" class="flex items-center gap-3 p-3 hover:bg-white/5 rounded-lg transition-colors text-sm font-semibold">
            <span>🏆</span> Koppelwedstrijden
          </a>
          <a href="/admin/kamp-izegem" class="flex items-center gap-3 p-3 hover:bg-white/5 rounded-lg transition-colors text-sm font-semibold"><span>🏅</span> Kamp. Izegem</a>
          <a href="/admin/specials/vrouwvissing" class="flex items-center gap-3 p-3 hover:bg-white/5 rounded-lg transition-colors text-sm font-semibold"><span>👩</span> Vrouwvissing</a>
          <a href="/admin/specials/seniorenvissing" class="flex items-center gap-3 p-3 hover:bg-white/5 rounded-lg transition-colors text-sm font-semibold"><span>👴</span> Seniorenvissing</a>
          <a href="/admin/tips-tricks" class="flex items-center gap-3 p-3 hover:bg-white/5 rounded-lg transition-colors text-sm font-semibold"><span>💡</span> Tips &amp; Tricks</a>
          <a href="/admin/fotos" class="flex items-center gap-3 p-3 hover:bg-white/5 rounded-lg transition-colors text-sm font-semibold">
            <span>📸</span> Foto's
          </a>
        </nav>

        <div class="p-4 border-t border-white/10">
          <a href="/" class="text-sm text-slate-400 hover:text-white transition-colors flex items-center gap-2">
            <span>←</span> Terug naar Website
          </a>
        </div>
      </aside>

      <!-- MOBILE OVERLAY -->
      <div id="mobile-overlay" class="fixed inset-0 bg-black/50 z-40 hidden"></div>
      <aside id="mobile-sidebar" class="md:hidden fixed top-0 left-0 w-72 bg-[#003366] text-white z-50 flex-col border-r-4 border-[#C5A059] h-screen hidden shadow-2xl">
        <nav class="flex-1 p-4 space-y-1 pt-6">
          <a href="/admin" class="flex items-center gap-3 p-3 hover:bg-white/5 rounded-lg transition-colors text-sm font-semibold">
            <span>🏠</span> Home
          </a>
          <a href="/admin/wedstrijden" class="flex items-center gap-3 p-3 hover:bg-white/5 rounded-lg transition-colors text-sm font-semibold">
            <span>🏆</span> Wedstrijden
          </a>
          <a href="/admin/kalender" class="flex items-center gap-3 p-3 hover:bg-white/5 rounded-lg transition-colors text-sm font-semibold">
            <span>📅</span> Kalender
          </a>
          <a href="/admin/visstekken" class="flex items-center gap-3 p-3 hover:bg-white/5 rounded-lg transition-colors text-sm font-semibold">
            <span>📍</span> Visstekken
          </a>
          <a href="/admin/visstekken-abc" class="flex items-center gap-3 p-3 hover:bg-white/5 rounded-lg transition-colors text-sm font-semibold">
            <span>🌐</span> ABC Visstekken
          </a>
          <a href="/admin/vissessies" class="flex items-center gap-3 p-3 hover:bg-white/5 rounded-lg transition-colors text-sm font-semibold">
            <span>📊</span> Vissessies
          </a>
          <a href="/admin/legende" class="flex items-center gap-3 p-3 hover:bg-white/5 rounded-lg transition-colors text-sm font-semibold">
            <span>📖</span> Legende
          </a>
          <a href="/admin/hengelshop" class="flex items-center gap-3 p-3 hover:bg-white/5 rounded-lg transition-colors text-sm font-semibold">
            <span>📦</span> Hengelshop
          </a>
          <a href="/admin/koppelwedstrijden" class="flex items-center gap-3 p-3 hover:bg-white/5 rounded-lg transition-colors text-sm font-semibold">
            <span>🏆</span> Koppelwedstrijden
          </a>
          <a href="/admin/kamp-izegem" class="flex items-center gap-3 p-3 hover:bg-white/5 rounded-lg transition-colors text-sm font-semibold"><span>🏅</span> Kamp. Izegem</a>
          <a href="/admin/specials/vrouwvissing" class="flex items-center gap-3 p-3 hover:bg-white/5 rounded-lg transition-colors text-sm font-semibold"><span>👩</span> Vrouwvissing</a>
          <a href="/admin/specials/seniorenvissing" class="flex items-center gap-3 p-3 hover:bg-white/5 rounded-lg transition-colors text-sm font-semibold"><span>👴</span> Seniorenvissing</a>
          <a href="/admin/tips-tricks" class="flex items-center gap-3 p-3 hover:bg-white/5 rounded-lg transition-colors text-sm font-semibold"><span>💡</span> Tips &amp; Tricks</a>
          <a href="/admin/fotos" class="flex items-center gap-3 p-3 hover:bg-white/5 rounded-lg transition-colors text-sm font-semibold">
            <span>📸</span> Foto's
          </a>
        </nav>
        <div class="p-4 border-t border-white/10">
          <a href="/" class="text-sm text-slate-400 hover:text-white transition-colors flex items-center gap-2">
            <span>←</span> Terug naar Website
          </a>
        </div>
      </aside>

      <!-- MAIN CONTENT -->
      <section class="flex-1 flex flex-col min-h-0 md:ml-64">
        <header class="h-16 bg-white border-b border-slate-200 flex items-center justify-between px-6 md:px-8">
          <div class="flex items-center gap-3">
            <span class="text-slate-400 text-sm">Admin</span>
            <span class="text-slate-300 text-sm">/</span>
            <span class="font-semibold text-sm">Home</span>
          </div>
          <span class="hidden sm:block text-right">
            <p class="text-xs font-bold text-[#003366]">KVVI ADMIN</p>
            <p class="text-[10px] text-slate-400">Control Panel</p>
          </span>
        </header>

        <div class="p-4 md:p-8 space-y-6 flex-1 overflow-y-auto">
          <!-- Welcome -->
          <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-8 text-center">
            <h2 class="text-2xl font-black text-[#003366] mb-2">🏠 Welkom bij KVVI Admin</h2>
            <p class="text-slate-500 text-sm">Beheer je visstekken, legende, foto's, specials en kalender.</p>
          </div>

          <!-- Quick links -->
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <a href="/admin/wedstrijden" class="bg-white rounded-xl shadow-sm border border-slate-200 p-6 hover:border-[#003366] transition flex items-center gap-4">
              <span class="text-3xl">🏆</span>
              <div>
                <h3 class="font-bold text-[#003366]">Wedstrijden</h3>
                <p class="text-xs text-slate-400">Beheer wedstrijden, uitslagen en deelnemers</p>
              </div>
            </a>
            <a href="/admin/kalender" class="bg-white rounded-xl shadow-sm border border-slate-200 p-6 hover:border-[#003366] transition flex items-center gap-4">
              <span class="text-3xl">📅</span>
              <div>
                <h3 class="font-bold text-[#003366]">Kalender</h3>
                <p class="text-xs text-slate-400">Beheer de wedstrijdkalender en reeksen</p>
              </div>
            </a>
            <a href="/admin/visstekken" class="bg-white rounded-xl shadow-sm border border-slate-200 p-6 hover:border-[#003366] transition flex items-center gap-4">
              <span class="text-3xl">📍</span>
              <div>
                <h3 class="font-bold text-[#003366]">Visstekken</h3>
                <p class="text-xs text-slate-400">Beheer de locaties en markers op de kaart</p>
              </div>
            </a>
            <a href="/admin/vissessies" class="bg-white rounded-xl shadow-sm border border-slate-200 p-6 hover:border-[#003366] transition flex items-center gap-4">
              <span class="text-3xl">📊</span>
              <div>
                <h3 class="font-bold text-[#003366]">Visstanden</h3>
                <p class="text-xs text-slate-400">Beheer vangstgegevens en statistieken</p>
              </div>
            </a>
            <a href="/admin/legende" class="bg-white rounded-xl shadow-sm border border-slate-200 p-6 hover:border-[#003366] transition flex items-center gap-4">
              <span class="text-3xl">📖</span>
              <div>
                <h3 class="font-bold text-[#003366]">Legende</h3>
                <p class="text-xs text-slate-400">Beheer watertypes en kleuren</p>
              </div>
            </a>
            <a href="/admin/fotos" class="bg-white rounded-xl shadow-sm border border-slate-200 p-6 hover:border-[#003366] transition flex items-center gap-4">
              <span class="text-3xl">📸</span>
              <div>
                <h3 class="font-bold text-[#003366]">Foto's</h3>
                <p class="text-xs text-slate-400">Beheer de fotogalerij</p>
              </div>
            </a>
            <a href="/admin/koppelwedstrijden" class="bg-white rounded-xl shadow-sm border border-slate-200 p-6 hover:border-[#003366] transition flex items-center gap-4">
              <span class="text-3xl">⭐</span>
              <div>
                <h3 class="font-bold text-[#003366]">Koppelwedstrijden</h3>
                <p class="text-xs text-slate-400">Beheer koppelwedstrijden</p>
              </div>
            </a>
          </div>
        </div>
      </section>
    </div>
  </main>

</Layout>

<script>
  const menuBtn = document.getElementById('mobile-menu-btn');
  const sidebar = document.getElementById('mobile-sidebar');
  const overlay = document.getElementById('mobile-overlay');

  if (menuBtn && sidebar && overlay) {
    function toggleMenu() {
      const hidden = sidebar.classList.contains('hidden');
      sidebar.classList.toggle('hidden', !hidden);
      overlay.classList.toggle('hidden', !hidden);
    }
    menuBtn.onclick = toggleMenu;
    overlay.onclick = toggleMenu;
  }
</script>

<style>
  body { overflow-x: hidden; }
  ::-webkit-scrollbar { width: 6px; }
  ::-webkit-scrollbar-track { background: #f1f5f9; }
  ::-webkit-scrollbar-thumb { background: #94a3b8; border-radius: 3px; }
</style>