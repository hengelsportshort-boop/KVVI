---
import BaseLayout from '../layouts/BaseLayout.astro';
export const prerender = false;
---

<BaseLayout title="Tips &amp; Tricks" description="Handige vis tips &amp; tricks van KVVI Izegem. Leer bij over technieken, materiaal en visplekken in West-Vlaanderen.">
  <main class="max-w-5xl mx-auto px-4 py-16">
    <h1 class="text-4xl font-black text-[#004A99] mb-12 uppercase tracking-tight text-center">Tips &amp; Tricks</h1>

    <div class="bg-gradient-to-br from-[#003366] to-[#004A99] rounded-2xl shadow-lg overflow-hidden mb-12">
      <div class="flex flex-col md:flex-row items-center gap-6 p-8">
        <img src="/icons/AppIcoon.png" alt="Sessie-Assistent" class="w-24 h-24 md:w-28 md:h-28 rounded-2xl shadow-md object-cover bg-white p-1" />
        <div class="flex-1 text-center md:text-left">
          <h2 class="text-2xl md:text-3xl font-black text-white mb-2">🎣 Sessie-Assistent</h2>
          <p class="text-white/80 leading-relaxed mb-4">
            Feeder timer, vangsten noteren en statistieken in &eacute;&eacute;n app.
            &Eacute;&eacute;n installatie, &eacute;&eacute;n opslag —
            data is direct zichtbaar tussen alle onderdelen.
          </p>
          <div class="flex flex-wrap gap-3 justify-center md:justify-start">
            <a href="/hengel-app" class="inline-flex items-center gap-2 bg-[#C5A059] hover:bg-[#b8923f] text-white font-bold px-6 py-3 rounded-xl text-lg transition-colors shadow-md" style="min-width:190px">🎣 Open Sessie-Assistent</a>
            <a href="/sessie-assistent-help" class="inline-flex items-center gap-2 bg-[#C5A059] hover:bg-[#b8923f] text-red-600 font-bold px-4 py-3 rounded-xl text-lg transition-colors shadow-md">Help</a>
          </div>
          <p class="text-white/50 text-xs mt-4">Combineert Feeder, Hengel &amp; statistieken. Installeerbaar op je startscherm.</p>
        </div>
      </div>
    </div>



    <div id="tips-container" class="space-y-8">
      <div class="text-center text-slate-400 py-20">
        <div class="inline-block w-8 h-8 border-2 border-slate-300 border-t-[#004A99] rounded-full animate-spin"></div>
        <p class="mt-4">Laden...</p>
      </div>
    </div>
  </main>
</BaseLayout>

<script>
(async () => {
  console.log('tips-tricks: start loading');
  try {
    const res = await fetch('/api/tips-tricks');
    console.log('tips-tricks: fetch done', res.status);
    const data = await res.json();
    console.log('tips-tricks: data loaded', { pageVisible: data.pageVisible, tips: data.tips?.length });
    const container = document.getElementById('tips-container');
    if (!data.pageVisible || !data.tips || !data.tips.length) {
      container.innerHTML = '<div class="text-center text-slate-400 py-20 italic">Nog geen tips &amp; tricks beschikbaar.</div>';
      return;
    }
    const visible = data.tips.filter(t => t.visible !== false);
    if (!visible.length) {
      container.innerHTML = '<div class="text-center text-slate-400 py-20 italic">Nog geen tips &amp; tricks beschikbaar.</div>';
      return;
    }
    container.innerHTML = visible.map(function(tip, idx) {
      var mediaHtml = '';
      var media = tip.media && Array.isArray(tip.media) ? tip.media : (tip.mediaUrl ? [tip.mediaUrl] : []);
      if (media.length) {
        var items = media.map(function(url) {
          if (!url) return '';
          var isVideo = /youtube\.com|youtu\.be|vimeo\.com/i.test(url);
          if (isVideo) {
            var videoId = '';
            var m = url.match(/(?:youtu\.be\/|youtube\.com(?:\/embed\/|\/v\/|\/watch\?v=))([\w\-]{11})/);
            if (m) videoId = m[1];
            if (videoId) {
              return '<div class="rounded-xl overflow-hidden shadow-md" style="height:250px"><iframe src="https://www.youtube.com/embed/' + videoId + '" class="w-full h-full" allowfullscreen loading="lazy"></iframe></div>';
            }
            return '<div class="rounded-xl overflow-hidden shadow-md" style="height:250px"><iframe src="' + url + '" class="w-full h-full" allowfullscreen loading="lazy"></iframe></div>';
          }
          return '<div style="height:250px" class="rounded-xl overflow-hidden shadow-md"><img src="' + url + '" alt="' + (tip.name ? tip.name.replace(/"/g,'&quot;') : '') + '" class="w-full h-full object-cover" loading="lazy" onerror="this.parentNode.innerHTML=\'<div class=\\\'bg-slate-100 rounded-xl p-8 text-center text-slate-400 h-full flex items-center justify-center\\\'><span class=\\\'text-3xl\\\'>📷</span><p class=\\\'mt-2\\\'>Media niet beschikbaar</p></div>\'" /></div>';
        }).join('');
        mediaHtml = '<div class="space-y-3">' + items + '</div>';
      }
      var linkHtml = '';
      if (tip.link) {
        linkHtml = '<div class="mt-3"><a href="' + tip.link + '" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-sm font-bold text-white bg-[#C5A059] hover:bg-[#b8923f] px-5 py-2.5 rounded-lg transition-colors">Bekijk meer →</a></div>';
      }
      var contentId = 'tip-content-' + idx;
      return '<div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">' +
        '<div class="flex items-center justify-between p-4 md:p-5 cursor-pointer hover:bg-slate-50 transition-colors" onclick="var s=document.getElementById(\'' + contentId + '\'); s.classList.toggle(\'hidden\'); this.querySelector(\'.toggle-icon\').textContent=s.classList.contains(\'hidden\')?\'\\u25B6\':\'\\u25BC\'">' +
          '<span class="text-lg md:text-xl font-bold text-[#003366]">' + tip.name.replace(/"/g,'&quot;') + '</span>' +
          '<span class="toggle-icon text-sm text-slate-400 ml-3 flex-shrink-0">▶</span>' +
        '</div>' +
        '<div id="' + contentId + '" class="hidden border-t border-slate-100">' +
          '<div class="flex flex-col md:flex-row' + (idx % 2 === 1 ? ' md:flex-row-reverse' : '') + '">' +
            (mediaHtml ? '<div class="md:w-1/2 shrink-0 p-4">' + mediaHtml + '</div>' : '') +
            '<div class="p-4 md:p-6 flex flex-col justify-center' + (mediaHtml ? ' md:w-1/2' : '') + '">' +
              (tip.info ? '<p class="text-slate-600 leading-relaxed mb-4 whitespace-pre-line">' + tip.info.replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/\n/g,'<br/>') + '</p>' : '') +
              (linkHtml || '') +
            '</div>' +
          '</div>' +
        '</div>' +
      '</div>';
    }).join('');
  } catch (e) {
    document.getElementById('tips-container').innerHTML = '<div class="text-center text-red-400 py-20 italic">Fout bij laden van tips &amp; tricks.</div>';
  }
})();
</script>
