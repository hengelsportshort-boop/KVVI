      sel.innerHTML = jaarOpties.map(function(y) { return '<option value="'+y+'"'+(y===actief?' selected':'')+'>'+y+'</option>'; }).join('');
      sel.addEventListener('change', function() { localStorage.setItem(JAAR_KEY, sel.value); renderData(); });
    }

    function fmtDecimal(v) { if (v==null||isNaN(v)) return '—'; return v.toFixed(1); }
    function fmtEenheid(m) { if (m == null || isNaN(m) || m <= 0) return '—'; var h = Math.floor(m/60); var min = m%60; return h+'u'+('0'+min).slice(-2)+'m'; }
    function fmtGewicht(g) { if (g==null||isNaN(g)) return '—'; return Number(g).toLocaleString('nl-NL',{minimumFractionDigits:0})+' gr'; }
    function fmtDuurVangst(min, aantal) { if (!min||!aantal) return '—'; var pv = min/aantal; var m = Math.floor(pv); var s = Math.round((pv-m)*60); return m+'m '+s+'s'; }
    function genId() { return '_'+Date.now().toString(36)+Math.random().toString(36).slice(2,6); }
    function ensureId(entry) { if (!entry._id) entry._id = genId(); return entry; }

    function computeFields(r) {
      var tm = r.tijdMin || (r.duurMin || 0);
      var gm = tm > 0 ? (r.gewicht / tm) : 0;
      var w4 = gm * 240;
      var dv = tm > 0 && r.aantal > 0 ? fmtDuurVangst(tm, r.aantal) : '—';
      var a = r.aantal || 0;
      var beoord = a >= 51 ? '*****' : a >= 36 ? '****' : a >= 20 ? '***' : a >= 11 ? '**' : '*';
      return { tijdMin: tm, gramMin: gm, wedstrijd4uur: w4, duurVangst: dv, beoordeling: beoord };
    }

