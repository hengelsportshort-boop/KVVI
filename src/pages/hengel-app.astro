          for (var i=0;i<data.length;i++) {
            if (data[i]._id === id) {
              if (!confirm('Verwijder sessie van '+data[i].datum+' (stek '+data[i].stek+')?')) return;
              data.splice(i, 1);
              saveData(data);
              renderData();
              showToast('🗑️ Verwijderd');
              return;
            }
          }
        });
      });

      renderStats(alleData, jaar);
    }

    function renderStats(alleData, jaar) {
      var data = filterJaar(alleData, jaar);
      var totaalKroes=0, totaalSchub=0, totaalSpiegel=0, totaalAnder=0, totaalAantal=0, totaalGewicht=0, totaalTijd=0;
      var stekCounts = {};
      for (var i=0; i<data.length; i++) {
        var r = data[i];
        var k = parseInt(r.kroes)||0, s = parseInt(r.schub)||0, p = parseInt(r.spiegel)||0, a = parseInt(r.ander)||0;
        totaalKroes+=k; totaalSchub+=s; totaalSpiegel+=p; totaalAnder+=a;
        totaalAantal += k+s+p+a;
        totaalGewicht += parseInt(r.gewicht)||(k*GEW_KROES+s*GEW_SCHUB+p*GEW_SPIEGEL+a*GEW_ANDER);
        totaalTijd += r.duurMin||0;
        var st = r.stek||'Onbekend';
        stekCounts[st] = (stekCounts[st]||0) + 1;
      }
      var stekRanking = Object.keys(stekCounts).sort(function(a,b) { return stekCounts[b]-stekCounts[a]; }).slice(0,5);
      var html = '<div class="d-stats-grid">';
      html += '<div class="d-stat-card"><div class="d-stat-val">'+totaalAantal+'</div><div class="d-stat-label">Totaal vis</div></div>';
      html += '<div class="d-stat-card"><div class="d-stat-val">'+(totaalGewicht/1000).toFixed(1)+' kg</div><div class="d-stat-label">Totaal gewicht</div></div>';
      html += '<div class="d-stat-card"><div class="d-stat-val">'+totaalKroes+'</div><div class="d-stat-label">Kroes</div></div>';
      html += '<div class="d-stat-card"><div class="d-stat-val">'+totaalSchub+'</div><div class="d-stat-label">Schub</div></div>';
      html += '<div class="d-stat-card"><div class="d-stat-val">'+totaalAnder+'</div><div class="d-stat-label">Ander</div></div>';
      html += '<div class="d-stat-card"><div class="d-stat-val">'+totaalTijd+' min</div><div class="d-stat-label">Tijd op het water</div></div>';
      if (totaalTijd > 0) html += '<div class="d-stat-card"><div class="d-stat-val">'+fmtDecimal(totaalGewicht/totaalTijd)+'</div><div class="d-stat-label">Gr/min</div></div>';
      html += '<div class="d-stat-card"><div class="d-stat-val">'+data.length+'</div><div class="d-stat-label">Sessies</div></div>';
      html += '</div>';
      if (stekRanking.length) {
        html += '<p class="d-sub" style="font-weight:700;margin:8px 0 4px">Top stekken</p><ol style="color:var(--text);font-size:14px;padding-left:20px">';
        for (var si=0; si<stekRanking.length; si++) {
          html += '<li>'+stekRanking[si]+' ('+stekCounts[stekRanking[si]]+' sessies)</li>';
        }
        html += '</ol>';
      }
      document.getElementById('d-stats-content').innerHTML = html;
    }

    // Tab switching for data subtabs
    document.querySelectorAll('.d-tab').forEach(function(btn) {
      btn.addEventListener('click', function() {
        document.querySelectorAll('.d-tab').forEach(function(b) { b.classList.remove('active'); });
        document.querySelectorAll('.d-panel').forEach(function(p) { p.classList.remove('show'); });
        this.classList.add('active');
        document.getElementById('d-tab-'+this.dataset.dtab).classList.add('show');
      });
    });

    // Beheer
    document.getElementById('d-clear').addEventListener('click', function() {
      if (confirm('Alle data wissen?')) { saveData([]); renderData(); showToast('Data gewist'); }
    });
    document.getElementById('d-remove-empty').addEventListener('click', function() {
      var data = loadData().filter(function(r) {
        var k = parseInt(r.kroes)||0, s = parseInt(r.schub)||0, p = parseInt(r.spiegel)||0, a = parseInt(r.ander)||0;
        return k+s+p+a > 0;
      });
      saveData(data); renderData(); showToast('Lege sessies verwijderd');
    });
    document.getElementById('d-export').addEventListener('click', function() {
      var data = JSON.stringify(loadData(), null, 2);
      var blob = new Blob([data], {type:'application/json'});
      var url = URL.createObjectURL(blob);
      var a = document.createElement('a'); a.href=url; a.download='vissessies-export.json'; a.click();
      URL.revokeObjectURL(url);
    });
    document.getElementById('d-import').addEventListener('click', function() {
      document.getElementById('d-import-file').click();
    });
    document.getElementById('d-import-file').addEventListener('change', function() {
      if (!this.files.length) return;
      var reader = new FileReader();
      reader.onload = function(e) {
        try {
          var imported = JSON.parse(e.target.result);
          if (!Array.isArray(imported)) throw new Error('Ongeldig formaat');
          var existing = loadData();
          for (var i=0; i<imported.length; i++) {
            var dup = false;
            for (var j=0; j<existing.length; j++) {
              if (existing[j].stek===imported[i].stek && existing[j].datum===imported[i].datum && existing[j].month===imported[i].month) { dup=true; break; }
            }
            if (!dup) existing.push(imported[i]);
          }
          sortData(existing); saveData(existing); renderData(); showToast('Geimporteerd: '+imported.length+' entries');
        } catch(err) { showToast('Fout bij importeren'); }
      };
      reader.readAsText(this.files[0]);
      this.value = '';
    });

    // Month collapse
    document.addEventListener('click', function(e) {
      var h = e.target.closest('.d-month-header');
      if (h) {
        var body = h.nextElementSibling;
        if (body) body.classList.toggle('collapsed');
        h.innerHTML = h.innerHTML.replace('▼','▶').replace('▶','▼');
      }
    });

    updateYearSelector();
    renderData();

    // Re-render on storage change
    window.addEventListener('storage', function(e) {
      if (e.key === STORAGE_KEY) renderData();
    });
    document.addEventListener('visibilitychange', function() {
      if (!document.hidden) renderData();
    });
  })();
})();
</script>
</body>
</html>
