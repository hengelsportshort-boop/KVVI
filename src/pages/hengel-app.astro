      }
      for (var g in groups) { groups[g].sort(function(a,b) { var p1=a.datum?a.datum.split('/'):[], p2=b.datum?b.datum.split('/'):[]; return p1.length===2&&p2.length===2?parseInt(p1[1])*100+parseInt(p1[0])-parseInt(p2[1])*100-parseInt(p2[0]):0; }); }

