      el.value = String(v).padStart(3, '0');
      updateAantal();
    }
    function calcDuur(beginVal, eindeVal) {
      if (!beginVal || !eindeVal) return null;
      function parse(t) {
        var m = t.match(/(\d{1,2})u\s*(\d{1,2})m/);
        if (m) return parseInt(m[1])*60+parseInt(m[2]);
        var m2 = t.match(/^(\d{3,4})$/);
        if (m2) { var s=m2[1].padStart(4,'0'); return parseInt(s.substring(0,2))*60+parseInt(s.substring(2,4)); }
        return null;
      }
      var b = parse(beginVal), e = parse(eindeVal);
      if (b != null && e != null && e > b) return e - b;
      return null;
    }
    function updateAantal() {
      var ids = ['i-kroes','i-schub','i-spiegel','i-ander'];
      var sum = ids.reduce(function(a,id) { return a+(parseInt(document.getElementById(id).value)||0); }, 0);
      document.getElementById('i-aantal').textContent = sum;
      var gram = (function(){var k=parseInt(document.getElementById('i-kroes').value)||0,s=parseInt(document.getElementById('i-schub').value)||0,p=parseInt(document.getElementById('i-spiegel').value)||0,a=parseInt(document.getElementById('i-ander').value)||0; return k*GEW_KROES+s*GEW_SCHUB+p*GEW_SPIEGEL+a*GEW_ANDER;})();
