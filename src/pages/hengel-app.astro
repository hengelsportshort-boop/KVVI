      var computed = filtered.map(function(r) {
        var duurMin = r.duurMin || calcDuur(r.begin, r.einde) || 0;
        var kroes = parseInt(r.kroes)||0, schub = parseInt(r.schub)||0, spiegel = parseInt(r.spiegel)||0, ander = parseInt(r.ander)||0;
        var aantal = kroes+schub+spiegel+ander;
        var gewicht = parseInt(r.gewicht) || (kroes*GEW_KROES+schub*GEW_SCHUB+spiegel*GEW_SPIEGEL+ander*GEW_ANDER);
        return { kroes:kroes, schub:schub, spiegel:spiegel, ander:ander, aantal:aantal, gewicht:gewicht, datum:r.datum, stek:r.stek, begin:r.begin, einde:r.einde, duurMin:duurMin, month:r.month };
      }).sort(function(a,b) { function sv(r) { var p=r.datum?r.datum.split('/'):[]; if (p.length!==2) return 999999999; var d=parseInt(p[0]),m=parseInt(p[1]),j=0,x=r.month&&r.month.match(/\b(\d{4})\b/); if(x)j=parseInt(x[1]); return j*10000+m*100+d; } return sv(a)-sv(b); });
      var html = '<table><thead><tr><th>Datum</th><th>Kroes</th><th>Schub</th><th>Spiegel</th><th>Ander</th><th>Aantal</th><th>Begin</th><th>Einde</th><th>Duur</th></tr></thead><tbody>';
      for (var i=0;i<computed.length;i++) {
