        html += '<tr><td>'+c.datum+'</td><td class="num">'+(c.kroes||'')+'</td><td class="num">'+(c.schub||'')+'</td><td class="num">'+(c.spiegel||'')+'</td><td class="num">'+(c.ander||'')+'</td><td class="num">'+c.aantal+'</td><td>'+(c.begin||'')+'</td><td>'+(c.einde||'')+'</td><td class="num">'+fmtTime(c.duurMin)+'</td></tr>';
      }
      var t = computed.reduce(function(acc,r) { return { kroes:acc.kroes+r.kroes, schub:acc.schub+r.schub, spiegel:acc.spiegel+r.spiegel, ander:acc.ander+r.ander, aantal:acc.aantal+r.aantal }; }, {kroes:0,schub:0,spiegel:0,ander:0,aantal:0});
