        html += '<div class="d-month-group"><div class="d-month-header">▼ '+month+'</div><div class="d-month-body"><table><thead><tr><th>Datum</th><th>Kroes</th><th>Schub</th><th>Spiegel</th><th>Ander</th><th>Aantal</th><th>Gewicht</th><th>Stek</th><th>Begin</th><th>Einde</th><th>Duur</th><th>Duur/vangst</th><th>⬆⬇</th><th>Beoord</th><th>Tijd Min</th><th>Gr/min</th><th>4u wedstrijd</th><th>🏆</th><th style="width:24px">✕</th></tr></thead><tbody>';
