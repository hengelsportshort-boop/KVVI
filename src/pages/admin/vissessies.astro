---
import Layout from '../../layouts/Layout.astro';
export const prerender = false;
const pageTitle = "Vissessies Beheer | KVVI Admin";
---

<style is:inline>
* { margin: 0; padding: 0; box-sizing: border-box; }
body { font-family: system-ui, -apple-system, sans-serif; background: #f1f5f9; color: #1e293b; }
h1 { font-size: 20px; margin-bottom: 4px; }
.sub { color: #64748b; font-size: 13px; margin-bottom: 16px; }
.tabs { display: flex; gap: 6px; margin-bottom: 12px; flex-wrap: wrap; }
.tab { padding: 8px 18px; border-radius: 8px; font-weight: 600; font-size: 13px; border: 1px solid #cbd5e1; background: #fff; cursor: pointer; }
.tab.active { background: #1e40af; color: #fff; border-color: #1e40af; }
.tab.danger { color: #dc2626; border-color: #fecaca; }
.panel { background: #fff; border-radius: 12px; border: 1px solid #e2e8f0; padding: 16px; margin-bottom: 12px; display: none; }
.panel.show { display: block; }
textarea { width: 100%; border: 1px solid #cbd5e1; border-radius: 8px; padding: 10px; font-family: monospace; font-size: 12px; resize: vertical; }
.btn { padding: 8px 18px; border-radius: 8px; font-weight: 600; font-size: 13px; border: none; cursor: pointer; }
.btn-primary { background: #1e40af; color: #fff; }
.btn-primary:hover { background: #1e3a8a; }
.btn-danger { background: #dc2626; color: #fff; }
.btn-danger:hover { background: #b91c1c; }
.btn-outline { border: 1px solid #cbd5e1; background: #fff; }
.btn-outline:hover { background: #f8fafc; }
.flex { display: flex; gap: 8px; align-items: center; flex-wrap: wrap; }
.mt-2 { margin-top: 8px; }
.mb-2 { margin-bottom: 8px; }
.w-full { width: 100%; }
table { width: 100%; border-collapse: collapse; font-size: 12px; }
th { background: #f8fafc; padding: 6px 4px; text-align: center !important; font-size: 11px; text-transform: uppercase; color: #64748b; border-bottom: 2px solid #e2e8f0; white-space: nowrap; }
td { padding: 4px; border-bottom: 1px solid #f1f5f9; vertical-align: top; text-align: center !important; }
td[contenteditable] { cursor: text; }
td[contenteditable]:focus { outline: 2px solid #3b82f6; outline-offset: -1px; border-radius: 2px; background: #eff6ff; }
.num { font-family: monospace; }
.month-group { margin-bottom: 16px; }
.month-header { background: #1e293b; color: #fff; padding: 6px 10px; border-radius: 6px 6px 0 0; font-weight: 700; font-size: 13px; display: flex; justify-content: space-between; cursor: pointer; user-select: none; }
.month-header:hover { background: #1e40af; }
.month-body { overflow-x: auto; overflow-y: hidden; -webkit-overflow-scrolling: touch; }
.month-body.collapsed { display: none; }
.subtotal { background: #f1f5f9; font-weight: 700; }
.subtotal td { border-top: 2px solid #94a3b8; padding-top: 6px; }
.grand-total { background: #1e293b; color: #fff; font-weight: 700; }
.grand-total td { padding: 8px 4px; }
.hidden { display: none; }
.badge { display: inline-block; padding: 1px 6px; border-radius: 4px; font-size: 11px; font-weight: 600; }
.badge-up { background: none; color: #16a34a; }
.badge-down { background: none; color: #dc2626; }
tr.wedstrijd { background: #fef9c3 !important; }
tr.wedstrijd td { border-bottom-color: #facc15; }
.empty-msg { text-align: center; color: #94a3b8; padding: 40px; font-style: italic; }
#toast { position: fixed; bottom: 20px; right: 20px; padding: 10px 20px; border-radius: 8px; color: #fff; font-weight: 600; font-size: 13px; opacity: 0; transition: opacity 0.3s; z-index: 999; }
#toast.show { opacity: 1; }
.sticky-header { position: sticky; top: 0; z-index: 100; background: #f1f5f9; padding: 12px 20px 8px; margin: 0 -16px 12px; border-bottom: 1px solid #e2e8f0; }
@media (max-width: 768px) { .sticky-header { padding: 10px 10px 6px; margin: 0 -16px 10px; } table { font-size: 11px; } td, th { padding: 3px 2px; } }
</style>

