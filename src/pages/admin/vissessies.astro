<script is:inline>
(function() {
  const menuBtn = document.getElementById('mobile-menu-btn');
  const sidebar = document.getElementById('mobile-sidebar');
  const overlay = document.getElementById('mobile-overlay');
  if (menuBtn && sidebar && overlay) {
    function toggleMenu() {
      const hidden = sidebar.classList.contains('hidden');
      sidebar.classList.toggle('hidden', !hidden);
      overlay.classList.toggle('hidden', !hidden);
    }
    menuBtn.onclick = toggleMenu;
    overlay.onclick = toggleMenu;
  }
})();

const STORAGE_KEY = 'kvvi_vissessies';
const JAAR_KEY = 'kvvi_jaar';
const API_URL = '/admin/api/vissessies';
const GEW_KROES = 300, GEW_SCHUB = 1500, GEW_SPIEGEL = 1600, GEW_ANDER = 100;

const jaarOpties = [];
(function initJaren() {
  const ditJaar = new Date().getFullYear();
  for (let y = 2026; y <= ditJaar + 5; y++) jaarOpties.push(y);
})();

function huidigJaar() {
  let j = localStorage.getItem(JAAR_KEY);
  if (j) { j = parseInt(j); if (jaarOpties.includes(j)) return j; }
  return new Date().getFullYear();
}

function bewaarJaar(j) {
  localStorage.setItem(JAAR_KEY, j.toString());
}

function filterJaar(data, jaar) {
  return data.filter(r => {
    if (!r.month) return false;
    const m = r.month.match(/\b(\d{4})\b/);
    return m && parseInt(m[1]) === jaar;
  });
}

function laadDataJaar(jaar) {
  return filterJaar(loadData(), jaar);
}

function loadData() {
  try {
    var d = JSON.parse(localStorage.getItem(STORAGE_KEY)) || [];
    var changed = false;
    d.forEach(function(item) { if (!item._id) { item._id = genId(); changed = true; } });
    if (changed) localStorage.setItem(STORAGE_KEY, JSON.stringify(d));
    return d;
  } catch { return []; }
}
function saveData(data) {
  localStorage.setItem(STORAGE_KEY, JSON.stringify(data));
  fetch(API_URL, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    credentials: 'include',
    body: JSON.stringify(data)
  }).catch(() => {});
}

function parseTime(t) {
  if (!t || t === '--') return null;
  const m = t.match(/(\d+)u\s*(\d+)m/);
  if (m) return parseInt(m[1]) * 60 + parseInt(m[2]);
  const m2 = t.match(/(\d+):(\d+)/);
  if (m2) return parseInt(m2[1]) * 60 + parseInt(m2[2]);
  const m3 = t.match(/^(\d{3,4})$/);
  if (m3) {
    const s = m3[1].padStart(4, '0');
    return parseInt(s.substring(0, 2)) * 60 + parseInt(s.substring(2, 4));
  }
  return null;
}

function fmtTime(min) {
  if (min == null || isNaN(min)) return '--';
  return Math.floor(min / 60) + 'u ' + (min % 60) + 'm';
}

function fmtGewicht(g) {
  if (g == null || isNaN(g)) return '--';
  return Number(g).toLocaleString('nl-NL', { minimumFractionDigits: 0 }) + ' gr';
}

function trendDetail(info) {
  const el = document.getElementById('trend-detail');
  if (!el) return;
  if (el.innerHTML === info) {
    el.style.display = 'none';
    el.innerHTML = '';
  } else {
    el.innerHTML = info;
    el.style.display = 'block';
  }
}

function fmtDecimal(n) {
  if (n == null || isNaN(n)) return '--';
  return n.toLocaleString('nl-NL', { maximumFractionDigits: 0 });
}

function fmtEenheid(n) {
  if (n == null || isNaN(n) || n === 0) return '--';
  return n.toLocaleString('nl-NL', { maximumFractionDigits: 0 });
}

function fmtDuurVangst(min, aantal) {
  if (!min || !aantal) return '--';
  const perVis = min / aantal;
  const m = Math.floor(perVis);
  const s = Math.round((perVis - m) * 60);
  return m + 'm ' + s + 's';
}

function formatTijdInput(val) {
  if (/^\d{3,4}$/.test(val)) {
    const s = val.padStart(4, '0');
    const h = parseInt(s.substring(0, 2));
    const m = parseInt(s.substring(2, 4));
    if (h >= 0 && h <= 23 && m >= 0 && m <= 59) {
      return h + 'u ' + m + 'm';
    }
  }
  return val;
}

function calcDuurVanBeginEinde(beginVal, eindeVal) {
  const b = parseTime(beginVal);
  const e = parseTime(eindeVal);
  if (b != null && e != null && e > b) return e - b;
  return null;
}

function showToast(msg, type) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.style.background = type === 'error' ? '#dc2626' : '#16a34a';
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 2500);
}

function isHeader(cols) {
  const keys = ['kroes', 'schub', 'spiegel', 'ander', 'aantal', 'gewicht', 'datum'];
  return keys.some(k => cols.join(' ').toLowerCase().includes(k));
}

const COL_COUNT = 17;

function detectOffset(cols) {
  if (cols.length < COL_COUNT - 3) return -1;
  const off = cols.length - COL_COUNT;
  if (off >= 0 && off <= 5) return off;
  return -1;
}

function parseTable(text) {
  const lines = text.split('\n').filter(l => l.trim());
  if (!lines.length) return [];
  const rows = [];
  let currentMonth = '';
  const monthRE = /^(jan|feb|mar|apr|mei|jun|jul|aug|sep|okt|nov|dec)/i;

  const headCols = lines[0].split('\t').map(c => c.trim());
  const hasHeader = isHeader(headCols);
  const startIdx = hasHeader ? 1 : 0;

  for (let i = startIdx; i < lines.length; i++) {
    const cols = lines[i].split('\t').map(c => c.trim());
    const c0 = cols[0] || '';
    const c1 = cols[1] || '';

    if (/som|totaal|kolom/i.test(c0 + ' ' + c1)) continue;
    if (/^[a-z]{3,4}\s*\d{0,4}$/i.test(c0) && !c1) {
      let m = c0;
      if (!/\d{4}/.test(m)) m += ' ' + huidigJaar();
      currentMonth = m;
      continue;
    }

    const off = detectOffset(cols);
    if (off < 0) continue;

    for (let p = 0; p < off; p++) {
      if (monthRE.test(cols[p] || '')) {
        let m = cols[p];
        if (!/\d{4}/.test(m)) m += ' ' + huidigJaar();
        currentMonth = m;
        break;
      }
    }

    function pn(idx) {
      const v = cols[idx + off];
      if (v == null || v === '' || v === '--') return 0;
      const n = parseInt(v);
      return isNaN(n) ? 0 : n;
    }
    function gr(idx) {
      return cols[idx + off] || '';
    }

    const kroes   = pn(0);
    const schub   = pn(1);
    const spiegel = pn(2);
    const ander   = pn(3);
    const aantal  = pn(4);
    const gewichtRaw = gr(5).replace(/[^0-9,]/g, '').replace(',', '.');
    const gewicht = parseFloat(gewichtRaw) || 0;
    const datum   = gr(6);
    const stek    = gr(7);
    const begin   = gr(8);
    const einde   = gr(9);
    const duurMin = parseTime(gr(10)) || (parseTime(begin) && parseTime(einde) ? parseTime(einde) - parseTime(begin) : 0);
    const pijl    = gr(12);
    const beoordeling = gr(13);
    const tijdMin = parseTime(gr(14)) || duurMin;

    rows.push({
      kroes, schub, spiegel, ander, aantal, gewicht,
      datum, stek, begin, einde, duurMin,
      duurVangstRaw: gr(11), pijl, beoordeling, tijdMin,
      month: currentMonth, wedstrijd: ''
    });
  }
  return rows;
}

function computeFields(row) {
  const tijdMin = row.tijdMin || (row.duurMin || 0);
  const gramMin = tijdMin > 0 ? (row.gewicht / tijdMin) : 0;
  const wedstrijd4uur = gramMin * 240;
  const duurVangst = tijdMin > 0 && row.aantal > 0 ? fmtDuurVangst(tijdMin, row.aantal) : '--';
  const a = row.aantal || 0;
  const beoordeling = a >= 51 ? '*****' : a >= 36 ? '****' : a >= 20 ? '***' : a >= 11 ? '**' : '*';
  return { ...row, tijdMin, gramMin, wedstrijd4uur, duurVangst, beoordeling };
}

function deriveMonth(datum, jaar) {
  if (!datum) return null;
  const m = datum.match(/\/(\d+)/);
  if (!m) return null;
  const mn = parseInt(m[1]);
  if (mn < 1 || mn > 12) return null;
  const maanden = ['jan','feb','mar','apr','mei','jun','jul','aug','sep','okt','nov','dec'];
  return maanden[mn - 1] + ' ' + (jaar != null ? jaar : new Date().getFullYear());
}

function genId() {
  return '_' + Date.now().toString(36) + Math.random().toString(36).slice(2, 6);
}

function ensureId(entry) {
  if (!entry._id) entry._id = genId();
  return entry;
}

function sortData(arr) {
  arr.forEach(ensureId);
  function dateVal(r) {
    const p = r.datum ? r.datum.split('/') : [];
    if (p.length === 2) return parseInt(p[1]) * 100 + parseInt(p[0]);
    return 99999;
  }
  return arr.sort((a, b) => {
    const ma = a.month, mb = b.month;
    if (ma !== mb) {
      const maanden = ['jan','feb','mar','apr','mei','jun','jul','aug','sep','okt','nov','dec'];
      const ra = ma.match(/([a-z]+)\s*(\d+)/i), rb = mb.match(/([a-z]+)\s*(\d+)/i);
      if (ra && rb) {
        const ya = parseInt(ra[2]), yb = parseInt(rb[2]);
        if (ya !== yb) return ya - yb;
        const da = maanden.indexOf(ra[1].toLowerCase().substring(0,3));
        const db = maanden.indexOf(rb[1].toLowerCase().substring(0,3));
        if (da !== db) return da - db;
      }
    }
    return dateVal(a) - dateVal(b);
  });
}

function render() {
  const alleData = loadData();
  const jaar = huidigJaar();
  bewaarJaar(jaar);
  const data = filterJaar(alleData, jaar);
  const container = document.getElementById('table-container');
  document.getElementById('row-count').textContent = data.length + ' sessies in ' + jaar;
  document.getElementById('year-count').textContent = '(' + alleData.length + ' totaal)';

  if (!data.length) {
    container.innerHTML = '<p class="empty-msg">Geen data voor ' + jaar + '. Ga naar Import om data te plakken, of kies een ander jaar.</p>';
    updateStats();
    return;
  }

  const groups = {};
  for (const r of data) {
    const m = r.month || 'Onbekend';
    if (!groups[m]) groups[m] = [];
    groups[m].push(r);
  }

  for (const m in groups) {
    groups[m].sort((a, b) => {
      function dateVal(r) {
        const p = r.datum ? r.datum.split('/') : [];
        return p.length === 2 ? parseInt(p[1]) * 100 + parseInt(p[0]) : 99999;
      }
      return dateVal(a) - dateVal(b);
    });
  }

  let html = '';
  const monthOrder = Object.keys(groups).sort((a, b) => {
    const maanden = ['jan','feb','mar','apr','mei','jun','jul','aug','sep','okt','nov','dec'];
    const ma = a.match(/([a-z]+)\s*(\d+)/i);
    const mb = b.match(/([a-z]+)\s*(\d+)/i);
    if (ma && mb) {
      const ya = parseInt(ma[2]), yb = parseInt(mb[2]);
      if (ya !== yb) return ya - yb;
      return maanden.indexOf(ma[1].toLowerCase().substring(0,3)) - maanden.indexOf(mb[1].toLowerCase().substring(0,3));
    }
    return 0;
  });

  let grandKroes = 0, grandSchub = 0, grandSpiegel = 0, grandAnder = 0;
  let grandAantal = 0, grandGewicht = 0, grandTijd = 0;
  let vorigeGramMin = -1;
  let globalIdx = 0;

  for (const month of monthOrder) {
    const items = groups[month];
    let mKroes = 0, mSchub = 0, mSpiegel = 0, mAnder = 0;
    let mAantal = 0, mGewicht = 0, mTijd = 0;

    let rows = '';
    items.forEach((r, idx) => {
      ensureId(r);
      const c = computeFields(r);
      mKroes += c.kroes; mSchub += c.schub; mSpiegel += c.spiegel; mAnder += c.ander;
      mAantal += c.aantal; mGewicht += c.gewicht; mTijd += c.tijdMin;
      const pijlAuto = vorigeGramMin < 0 ? '–' : c.gramMin > vorigeGramMin ? '⬆' : c.gramMin < vorigeGramMin ? '⬇' : '–';
      vorigeGramMin = c.gramMin;
      const pijlClass = pijlAuto === '⬆' ? 'badge-up' : pijlAuto === '⬇' ? 'badge-down' : '';
      const wedstrijdClass = c.wedstrijd ? ' wedstrijd' : '';
      rows += `<tr style="text-align:center" class="${wedstrijdClass}">
        <td contenteditable="true" data-id="${c._id}" data-field="datum">${c.datum}</td>
        <td contenteditable="true" data-id="${c._id}" data-field="kroes" class="num">${c.kroes || ''}</td>
        <td contenteditable="true" data-id="${c._id}" data-field="schub" class="num">${c.schub || ''}</td>
        <td contenteditable="true" data-id="${c._id}" data-field="spiegel" class="num">${c.spiegel || ''}</td>
        <td contenteditable="true" data-id="${c._id}" data-field="ander" class="num">${c.ander || ''}</td>
        <td class="num">${c.aantal}</td>
        <td contenteditable="true" data-id="${c._id}" data-field="gewicht" class="num">${c.gewicht}</td>
        <td contenteditable="true" data-id="${c._id}" data-field="stek" class="col-merk">${c.stek}</td>
        <td contenteditable="true" data-id="${c._id}" data-field="begin">${c.begin}</td>
        <td contenteditable="true" data-id="${c._id}" data-field="einde">${c.einde}</td>
        <td class="num">${fmtTime(c.duurMin)}</td>
        <td class="num">${c.duurVangst}</td>
        <td class="${pijlClass}" style="font-size:18px;line-height:1">${pijlAuto}</td>
        <td style="font-weight:700;letter-spacing:2px">${c.beoordeling}</td>
        <td class="num">${fmtEenheid(c.tijdMin)}</td>
        <td class="num">${fmtDecimal(c.gramMin)}</td>
        <td class="num">${fmtDecimal(c.wedstrijd4uur)}</td>
        <td data-id="${c._id}" data-field="wedstrijd" class="wedstrijd-toggle" style="cursor:pointer;font-size:16px">${c.wedstrijd ? '🏆' : '⬜'}</td>
        <td style="cursor:pointer;color:#ef4444;font-weight:700" class="row-delete" data-id="${c._id}">✕</td>
      </tr>`;
    });

    grandKroes += mKroes; grandSchub += mSchub; grandSpiegel += mSpiegel; grandAnder += mAnder;
    grandAantal += mAantal; grandGewicht += mGewicht; grandTijd += mTijd;

    const collKey = 'kvvi_collapse_' + month.replace(/\s+/g, '_');
    const isCollapsed = localStorage.getItem(collKey) === '1';
    html += `<div class="month-group">
      <div class="month-header" data-collapse="${collKey}">
        <span>${isCollapsed ? '▶' : '▼'} ${month}</span>
        <span>${mAantal} vis — ${fmtGewicht(mGewicht)} — ${fmtTime(mTijd)} — ${fmtDecimal(mTijd > 0 ? mGewicht / mTijd : 0)} gr/min</span>
      </div>
      <div class="month-body${isCollapsed ? ' collapsed' : ''}">
      <table><thead><tr style="text-align:center">
        <th>Datum</th><th>Kroes</th><th>Schub</th><th>Spiegel</th><th>Ander</th><th>Aantal</th><th>Gewicht</th><th>Stek</th><th>Begin</th><th>Einde</th><th>Duur</th><th>Duur/vangst</th><th>⬆⬇</th><th>Beoord</th><th>Tijd Min</th><th>Gr/min</th><th>4u wedstrijd</th><th>🏆</th><th style="width:24px">✕</th>
      </tr></thead><tbody>${rows}
      <tr class="subtotal" style="text-align:center"><td style="text-align:left;font-weight:600">Subtotaal ${month}</td><td class="num">${mKroes || ''}</td><td class="num">${mSchub || ''}</td><td class="num">${mSpiegel || ''}</td><td class="num">${mAnder || ''}</td><td class="num">${mAantal}</td><td class="num">${fmtGewicht(mGewicht)}</td><td></td><td></td><td></td><td class="num">${fmtTime(mTijd)}</td><td></td><td></td><td></td><td class="num">${fmtEenheid(mTijd)}</td><td class="num">${fmtDecimal(mTijd > 0 ? mGewicht / mTijd : 0)}</td><td class="num">${fmtDecimal((mTijd > 0 ? mGewicht / mTijd : 0) * 240)}</td><td></td><td></td></tr>
    </tbody></table></div></div>`;
  }

  html += `<div style="background:#1e40af;color:#fff;padding:12px 16px;border-radius:8px;display:flex;gap:24px;flex-wrap:wrap;font-size:15px;font-weight:700;margin-top:12px">
    <span>🎣 ${grandAantal} vis</span>
    <span>⚖️ ${fmtGewicht(grandGewicht)}</span>
    <span>📅 ${data.length} sessies</span>
    <span>⏱️ ${fmtTime(grandTijd)}</span>
    <span>📊 ${fmtDecimal(grandTijd > 0 ? grandGewicht / grandTijd : 0)} gr/min</span>
  </div>`;

  container.innerHTML = html;

  container.querySelectorAll('td[contenteditable]').forEach(td => {
    td.addEventListener('blur', () => {
      const field = td.dataset.field;
      const id = td.dataset.id;
      const val = td.textContent.trim();
      const data = loadData();
      const found = id ? data.find(r => r._id === id) : null;
      if (found) {
        if (field === 'datum') {
          const yearMatch = found.month && found.month.match(/(\d{4})/);
          const jaar = yearMatch ? parseInt(yearMatch[1]) : undefined;
          const newMonth = deriveMonth(val, jaar);
          if (newMonth) found.month = newMonth;
        }
        if (field === 'kroes' || field === 'schub' || field === 'spiegel' || field === 'ander' || field === 'gewicht') {
          found[field] = parseInt(val) || 0;
          if (field === 'kroes' || field === 'schub' || field === 'spiegel' || field === 'ander') {
            found.aantal = (found.kroes || 0) + (found.schub || 0) + (found.spiegel || 0) + (found.ander || 0);
            found.gewicht = (found.kroes || 0) * GEW_KROES + (found.schub || 0) * GEW_SCHUB + (found.spiegel || 0) * GEW_SPIEGEL + (found.ander || 0) * GEW_ANDER;
          }
        } else {
          found[field] = val;
          if (field === 'begin' || field === 'einde') {
            const d = calcDuurVanBeginEinde(found.begin, found.einde);
            if (d != null) found.duurMin = d;
          }
        }
        sortData(data);
        saveData(data);
        render();
        showToast('✅ Bijgewerkt');
      }
    });
    td.addEventListener('keydown', e => {
      if (e.key === 'Enter') { e.preventDefault(); td.blur(); }
    });
  });

  container.querySelectorAll('td.wedstrijd-toggle').forEach(td => {
    td.addEventListener('click', () => {
      const id = td.dataset.id;
      const data = loadData();
      const found = id ? data.find(r => r._id === id) : null;
      if (found) {
        found.wedstrijd = found.wedstrijd ? '' : '🏆';
        saveData(data);
        render();
        showToast(found.wedstrijd ? '🏆 Wedstrijd' : '⬜ Normaal');
      }
    });
  });

  container.querySelectorAll('td.row-delete').forEach(td => {
    td.addEventListener('click', () => {
      const id = td.dataset.id;
      const data = loadData();
      const idx = id ? data.findIndex(r => r._id === id) : -1;
      if (idx >= 0) {
        if (!confirm(`Verwijder sessie van ${data[idx].datum} (stek ${data[idx].stek})?`)) return;
        data.splice(idx, 1);
        saveData(data);
        render();
        showToast('🗑️ Verwijderd');
      }
    });
  });

  container.querySelectorAll('.month-header').forEach(header => {
    header.addEventListener('click', () => {
      const collKey = header.dataset.collapse;
      if (!collKey) return;
      const body = header.nextElementSibling;
      if (!body || !body.classList.contains('month-body')) return;
      const isNowCollapsed = body.classList.toggle('collapsed');
      localStorage.setItem(collKey, isNowCollapsed ? '1' : '0');
      const span = header.querySelector('span:first-child');
      if (span) span.textContent = (isNowCollapsed ? '▶' : '▼') + span.textContent.slice(1);
    });
  });

  updateStats();
}

function updateStats() {
  const alleData = loadData();
  const jaar = huidigJaar();
  const data = filterJaar(alleData, jaar);
  const el = document.getElementById('stats-content');
  if (!alleData.length) {
    el.innerHTML = '<p class="empty-msg">Importeer eerst data.</p>';
    return;
  }
  if (!data.length) {
    el.innerHTML = '<p class="empty-msg">Geen data voor ' + jaar + '.</p>';
    return;
  }

  const computed = data.map(r => computeFields(r));
  const total = computed.reduce((a, r) => ({
    kroes: a.kroes + r.kroes, schub: a.schub + r.schub,
    spiegel: a.spiegel + r.spiegel, ander: a.ander + r.ander,
    aantal: a.aantal + r.aantal, gewicht: a.gewicht + r.gewicht,
    tijdMin: a.tijdMin + r.tijdMin
  }), { kroes: 0, schub: 0, spiegel: 0, ander: 0, aantal: 0, gewicht: 0, tijdMin: 0 });

  const metVangst = computed.filter(r => r.aantal > 0);
  const gemGramMin = total.tijdMin > 0 ? total.gewicht / total.tijdMin : 0;
  const sessieGem = data.length > 0 ? total.gewicht / data.length : 0;
  const gemPerVis = total.aantal > 0 ? total.gewicht / total.aantal : 0;

  const maanden = ['jan','feb','mar','apr','mei','jun','jul','aug','sep','okt','nov','dec'];
  const perMaand = {};
  for (const r of computed) {
    const m = r.month ? r.month.match(/([a-z]+)/i) : null;
    const key = m ? m[1].toLowerCase().substring(0,3) : 'onb';
    if (!perMaand[key]) perMaand[key] = { aantal: 0, gewicht: 0, tijd: 0, sessies: 0 };
    perMaand[key].aantal += r.aantal;
    perMaand[key].gewicht += r.gewicht;
    perMaand[key].tijd += r.tijdMin;
    perMaand[key].sessies++;
  }
  const maxMaandAantal = Math.max(...Object.values(perMaand).map(v => v.aantal), 1);
  const maxMaandGewicht = Math.max(...Object.values(perMaand).map(v => v.gewicht), 1);

  const beste = [...computed].filter(r => r.aantal > 0).sort((a, b) => b.gramMin - a.gramMin).slice(0, 5);

  const steken = {};
  for (const r of computed) {
    if (r.stek && r.stek !== '--') {
      if (!steken[r.stek]) steken[r.stek] = { aantal: 0, gewicht: 0, sessies: 0 };
      steken[r.stek].aantal += r.aantal;
      steken[r.stek].gewicht += r.gewicht;
      steken[r.stek].sessies++;
    }
  }

  const trendData = [...computed].filter(r => r.aantal > 0 && r.datum).sort((a, b) => {
    function dv(r) { const p = r.datum.split('/'); return p.length === 2 ? parseInt(p[1])*100 + parseInt(p[0]) : 99999; }
    return dv(a) - dv(b);
  });

  let html = '';

  const leeg = data.length - metVangst.length;
  html += '<div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:10px;margin-bottom:20px">' +
    '<div style="background:#fff;border-radius:12px;border:1px solid #e2e8f0;padding:14px;text-align:center">' +
      '<div style="font-size:11px;text-transform:uppercase;color:#64748b;font-weight:600;letter-spacing:0.5px">Totaal vis</div>' +
      '<div style="font-size:28px;font-weight:800;color:#1e293b;margin-top:4px">' + total.aantal.toLocaleString('nl-NL') + '</div></div>' +
    '<div style="background:#fff;border-radius:12px;border:1px solid #e2e8f0;padding:14px;text-align:center">' +
      '<div style="font-size:11px;text-transform:uppercase;color:#64748b;font-weight:600;letter-spacing:0.5px">Totaal gewicht</div>' +
      '<div style="font-size:28px;font-weight:800;color:#1e293b;margin-top:4px">' + (total.gewicht/1000).toLocaleString('nl-NL',{maximumFractionDigits:1}) + ' <span style="font-size:14px;font-weight:600;color:#64748b">kg</span></div></div>' +
    '<div style="background:#fff;border-radius:12px;border:1px solid #e2e8f0;padding:14px;text-align:center">' +
      '<div style="font-size:11px;text-transform:uppercase;color:#64748b;font-weight:600;letter-spacing:0.5px">Gr/min</div>' +
      '<div style="font-size:28px;font-weight:800;color:#1e293b;margin-top:4px">' + Math.round(gemGramMin).toLocaleString('nl-NL') + '</div></div>' +
    '<div style="background:#fff;border-radius:12px;border:1px solid #e2e8f0;padding:14px;text-align:center">' +
      '<div style="font-size:11px;text-transform:uppercase;color:#64748b;font-weight:600;letter-spacing:0.5px">Gem. vis/sessie</div>' +
      '<div style="font-size:28px;font-weight:800;color:#1e293b;margin-top:4px">' + (total.aantal/data.length).toLocaleString('nl-NL',{maximumFractionDigits:1}) + '</div></div>' +
    '<div style="background:#fff;border-radius:12px;border:1px solid #e2e8f0;padding:14px;text-align:center">' +
      '<div style="font-size:11px;text-transform:uppercase;color:#64748b;font-weight:600;letter-spacing:0.5px">Gem. gewicht/vis</div>' +
      '<div style="font-size:28px;font-weight:800;color:#1e293b;margin-top:4px">' + (gemPerVis/1000).toLocaleString('nl-NL',{maximumFractionDigits:2}) + ' <span style="font-size:14px;font-weight:600;color:#64748b">kg</span></div></div>' +
    '<div style="background:#fff;border-radius:12px;border:1px solid #e2e8f0;padding:14px;text-align:center">' +
      '<div style="font-size:11px;text-transform:uppercase;color:#64748b;font-weight:600;letter-spacing:0.5px">Sessies</div>' +
      '<div style="font-size:28px;font-weight:800;color:#1e293b;margin-top:4px">' + data.length + ' <span style="font-size:13px;font-weight:600;color:' + (leeg > 0 ? '#dc2626' : '#16a34a') + '">(' + (leeg > 0 ? leeg + ' leeg' : 'vol') + ')</span></div></div>' +
  '</div>';

  const jaarData = {};
  for (const r of alleData) {
    const m = r.month || '';
    const y = m.match(/(\d{4})/);
    const jr = y ? parseInt(y[1]) : 0;
    if (!jr) continue;
    if (!jaarData[jr]) jaarData[jr] = [];
    jaarData[jr].push(computeFields(r));
  }
  const jaren = Object.keys(jaarData).sort();
  if (jaren.length > 1) {
    html += '<div style="background:#fff;border-radius:12px;border:1px solid #e2e8f0;padding:16px;margin-bottom:20px">' +
      '<div style="font-size:13px;font-weight:700;color:#1e293b;margin-bottom:12px">Jaarvergelijking</div>';
    const metrics = [
      { key: 'aantal', label: 'Totaal vis', suffix: '' },
      { key: 'gewicht', label: 'Totaal gewicht', suffix: ' kg', div: 1000, fmt: v => (v/1000).toFixed(1) },
      { key: 'sessies', label: 'Sessies', suffix: '' },
      { key: 'gramMin', label: 'Gr/min', suffix: '', fmt: v => Math.round(v) },
    ];
    for (const m of metrics) {
      const vals = jaren.map(j => {
        const c = jaarData[j];
        let total;
        if (m.key === 'sessies') total = c.length;
        else if (m.key === 'gramMin') {
          const tot = c.reduce((a, r) => ({gewicht: a.gewicht + r.gewicht, tijd: a.tijd + r.tijdMin}), {gewicht: 0, tijd: 0});
          total = tot.tijd > 0 ? tot.gewicht / tot.tijd : 0;
        }
        else total = c.reduce((a, r) => a + (r[m.key] || 0), 0);
        if (m.div) total = total / m.div;
        return { jr: j, val: total };
      });
      const maxVal = Math.max(...vals.map(v => v.val), 1);
      html += '<div style="margin-bottom:10px"><div style="font-size:11px;font-weight:600;color:#64748b;margin-bottom:4px">' + m.label + '</div>';
      for (const v of vals) {
        const pct = Math.max(3, (v.val / maxVal) * 100);
        const isCurrent = parseInt(v.jr) === parseInt(jaar);
        html += '<div style="display:flex;align-items:center;gap:6px;margin-bottom:3px;font-size:11px">' +
          '<div style="width:32px;font-weight:' + (isCurrent ? '700' : '500') + ';color:' + (isCurrent ? '#1e40af' : '#64748b') + '">' + v.jr + '</div>' +
          '<div style="flex:1;height:16px;background:#f1f5f9;border-radius:3px;overflow:hidden">' +
            '<div style="height:100%;width:' + pct + '%;background:' + (isCurrent ? '#1e40af' : '#94a3b8') + ';border-radius:3px;display:flex;align-items:center;padding-left:4px">' +
              '<span style="font-size:8px;font-weight:600;color:#fff;white-space:nowrap">' + (m.fmt ? m.fmt(v.val) : v.val.toLocaleString('nl-NL')) + m.suffix + '</span></div></div></div>';
      }
      html += '</div>';
    }
    html += '</div>';
  }

  html += '<div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:20px">' +
    '<div style="background:#fff;border-radius:12px;border:1px solid #e2e8f0;padding:16px">' +
      '<div style="font-size:13px;font-weight:700;color:#1e293b;margin-bottom:12px">Vis per maand</div>';
  for (const m of maanden) {
    const v = perMaand[m];
    if (!v) continue;
    const pct = Math.max(4, (v.aantal / maxMaandAantal) * 100);
    html += '<div style="display:flex;align-items:center;gap:8px;margin-bottom:6px">' +
      '<div style="width:28px;font-size:11px;font-weight:600;color:#64748b;text-align:right">' + m + '</div>' +
      '<div style="flex:1;height:22px;background:#f1f5f9;border-radius:4px;overflow:hidden">' +
        '<div style="height:100%;width:' + pct + '%;background:#1e40af;border-radius:4px;display:flex;align-items:center;padding-left:6px">' +
          '<span style="font-size:10px;font-weight:700;color:#fff;white-space:nowrap">' + v.aantal + '</span></div></div></div>';
  }
  html += '</div>' +
    '<div style="background:#fff;border-radius:12px;border:1px solid #e2e8f0;padding:16px">' +
      '<div style="font-size:13px;font-weight:700;color:#1e293b;margin-bottom:12px">Gewicht per maand</div>';
  for (const m of maanden) {
    const v = perMaand[m];
    if (!v) continue;
    const pct = Math.max(4, (v.gewicht / maxMaandGewicht) * 100);
    html += '<div style="display:flex;align-items:center;gap:8px;margin-bottom:6px">' +
      '<div style="width:28px;font-size:11px;font-weight:600;color:#64748b;text-align:right">' + m + '</div>' +
      '<div style="flex:1;height:22px;background:#f1f5f9;border-radius:4px;overflow:hidden">' +
        '<div style="height:100%;width:' + pct + '%;background:#16a34a;border-radius:4px;display:flex;align-items:center;padding-left:6px">' +
          '<span style="font-size:10px;font-weight:700;color:#fff;white-space:nowrap">' + (v.gewicht/1000).toFixed(1) + '</span></div></div></div>';
  }
  html += '</div></div>';

  const soorten = [
    { label: 'Kroes', count: total.kroes, color: '#3b82f6' },
    { label: 'Schub', count: total.schub, color: '#10b981' },
    { label: 'Spiegel', count: total.spiegel, color: '#f59e0b' },
    { label: 'Ander', count: total.ander, color: '#8b5cf6' },
  ];
  const maxSoort = Math.max(...soorten.map(s => s.count), 1);
  html += '<div style="background:#fff;border-radius:12px;border:1px solid #e2e8f0;padding:16px;margin-bottom:20px">' +
    '<div style="font-size:13px;font-weight:700;color:#1e293b;margin-bottom:12px">Vissoort verdeling</div>';
  for (const s of soorten) {
    if (s.count <= 0) continue;
    const pct = total.aantal > 0 ? (s.count / total.aantal * 100) : 0;
    const barPct = Math.max(4, (s.count / maxSoort) * 100);
    html += '<div style="display:flex;align-items:center;gap:8px;margin-bottom:6px">' +
      '<div style="width:54px;font-size:11px;font-weight:600;color:#64748b;text-align:right">' + s.label + '</div>' +
      '<div style="flex:1;height:22px;background:#f1f5f9;border-radius:4px;overflow:hidden">' +
        '<div style="height:100%;width:' + barPct + '%;background:' + s.color + ';border-radius:4px;display:flex;align-items:center;padding-left:6px">' +
          '<span style="font-size:10px;font-weight:700;color:#fff;white-space:nowrap">' + s.count + ' (' + pct.toFixed(0) + '%)</span></div></div></div>';
  }
  html += '</div>';

  if (trendData.length >= 2) {
    const W = 600, H = 180, padL = 40, padR = 16, padT = 16, padB = 28;
    const cw = W - padL - padR, ch = H - padT - padB;
    const maxVal = Math.max(...trendData.map(r => r.gramMin), 1);
    const range = maxVal || 1;
    const points = trendData.map((r, i) => {
      const x = padL + (i / (trendData.length - 1)) * cw;
      const y = padT + ch - (r.gramMin / range) * ch;
      return x + ',' + y;
    });
    const yTicks = [0, Math.round(maxVal/2), Math.round(maxVal)];
    html += '<div style="background:#fff;border-radius:12px;border:1px solid #e2e8f0;padding:16px;margin-bottom:20px">' +
      '<div style="font-size:13px;font-weight:700;color:#1e293b;margin-bottom:8px">Trend — gr/min per sessie</div>' +
      '<div style="overflow-x:auto">' +
        '<svg viewBox="0 0 ' + W + ' ' + H + '" style="width:100%;max-width:100%;height:auto">' +
          '<line x1="' + padL + '" y1="' + padT + '" x2="' + padL + '" y2="' + (padT+ch) + '" stroke="#e2e8f0" stroke-width="1"/>' +
          '<line x1="' + padL + '" y1="' + (padT+ch) + '" x2="' + (padL+cw) + '" y2="' + (padT+ch) + '" stroke="#e2e8f0" stroke-width="1"/>';
    for (const v of yTicks) {
      const y = padT + ch - (v / range) * ch;
      html += '<text x="' + (padL-6) + '" y="' + (y+4) + '" text-anchor="end" font-size="10" fill="#94a3b8">' + v + '</text>' +
        '<line x1="' + padL + '" y1="' + y + '" x2="' + (padL+cw) + '" y2="' + y + '" stroke="#f1f5f9" stroke-width="1"/>';
    }
    html += '<polyline points="' + points.join(' ') + '" fill="none" stroke="#1e40af" stroke-width="2" stroke-linejoin="round"/>';
    for (let i = 0; i < trendData.length; i++) {
      const r = trendData[i];
      const x = padL + (i / (trendData.length - 1)) * cw;
      const y = padT + ch - (r.gramMin / range) * ch;
      const info = r.datum + ' — ' + (r.stek || '--') + ': ' + r.aantal + ' vis · ' + fmtGewicht(r.gewicht) + ' · ' + Math.round(r.gramMin).toLocaleString('nl-NL') + ' gr/min';
      html += '<circle cx="' + x + '" cy="' + y + '" r="5" fill="#fff" stroke="#1e40af" stroke-width="2" style="cursor:pointer" onclick="trendDetail(\'' + info.replace(/'/g, "\\'") + '\')">' +
        '<title>' + info + '</title></circle>';
    }
    for (let i = 0; i < trendData.length; i++) {
      const x = padL + (i / (trendData.length - 1)) * cw;
      const anchor = i === 0 ? 'start' : i === trendData.length-1 ? 'end' : 'middle';
      html += '<text x="' + x + '" y="' + (padT+ch+14) + '" text-anchor="' + anchor + '" font-size="8" fill="#94a3b8" transform="rotate(-45,' + x + ',' + (padT+ch+14) + ')">' + trendData[i].datum + '</text>';
    }
    html += '</svg></div>' +
      '<div id="trend-detail" style="display:none;margin-top:8px;padding:8px 12px;background:#f8fafc;border-radius:6px;font-size:12px;color:#1e293b;font-weight:500">' +
      '</div></div>';
  }

  function renderTopSessies(sessies, label, borderColor) {
    if (!sessies.length) return '';
    const maxVal = sessies[0].gramMin || 1;
    let h = '<div style="background:#fff;border-radius:12px;border:1px solid #e2e8f0;border-left:3px solid ' + borderColor + ';padding:14px;margin-bottom:12px">' +
      '<div style="font-size:12px;font-weight:600;color:#1e293b;margin-bottom:10px">' + label + '</div>';
    for (let i = 0; i < sessies.length; i++) {
      const r = sessies[i];
      const pct = Math.max(3, (r.gramMin / maxVal) * 100);
      h += '<div style="display:flex;align-items:center;gap:6px;margin-bottom:4px;font-size:12px">' +
        '<div style="width:16px;font-weight:600;color:#94a3b8">' + (i+1) + '</div>' +
        '<div style="width:42px;font-weight:500;color:#1e293b">' + r.datum + '</div>' +
        '<div style="width:36px;font-size:11px;color:#64748b;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">' + (r.stek || '--') + '</div>' +
        '<div style="flex:1;height:18px;background:#f8fafc;border-radius:3px;overflow:hidden">' +
          '<div style="height:100%;width:' + pct + '%;background:' + borderColor + ';border-radius:3px;display:flex;align-items:center;padding-left:5px">' +
            '<span style="font-size:9px;font-weight:600;color:#fff;white-space:nowrap">' + Math.round(r.gramMin).toLocaleString('nl-NL') + ' gr/min · ' + r.aantal + ' vis</span></div></div></div>';
    }
    h += '</div>';
    return h;
  }

  const besteG = [...computed].filter(r => r.aantal > 0 && r.stek && r.stek.match(/^G/i)).sort((a, b) => b.gramMin - a.gramMin).slice(0, 5);
  const besteAndere = [...computed].filter(r => r.aantal > 0 && (!r.stek || !r.stek.match(/^G/i))).sort((a, b) => b.gramMin - a.gramMin).slice(0, 5);
  if (besteG.length || besteAndere.length) {
    html += '<div style="margin-bottom:20px">' +
      '<div style="font-size:13px;font-weight:700;color:#1e293b;margin-bottom:10px">Top 5 sessies (gr/min)</div>';
    html += renderTopSessies(besteG, 'G-stekken', '#3b82f6');
    html += renderTopSessies(besteAndere, 'Andere', '#64748b');
    html += '</div>';
  }

  function renderTopStekken(entries, label, borderColor) {
    if (!entries.length) return '';
    const maxVal = entries[0][1].gewicht / entries[0][1].sessies || 1;
    let h = '<div style="background:#fff;border-radius:12px;border:1px solid #e2e8f0;border-left:3px solid ' + borderColor + ';padding:14px;margin-bottom:12px">' +
      '<div style="font-size:12px;font-weight:600;color:#1e293b;margin-bottom:10px">' + label + '</div>';
    for (let i = 0; i < entries.length; i++) {
      const [stek, s] = entries[i];
      const gem = s.gewicht / s.sessies / 1000;
      const pct = Math.max(3, (gem / (maxVal/1000)) * 100);
      h += '<div style="display:flex;align-items:center;gap:6px;margin-bottom:4px;font-size:12px">' +
        '<div style="width:16px;font-weight:600;color:#94a3b8">' + (i+1) + '</div>' +
        '<div style="width:42px;font-weight:500;color:#1e293b">' + stek + '</div>' +
        '<div style="flex:1;height:18px;background:#f8fafc;border-radius:3px;overflow:hidden">' +
          '<div style="height:100%;width:' + pct + '%;background:' + borderColor + ';border-radius:3px;display:flex;align-items:center;padding-left:5px">' +
            '<span style="font-size:9px;font-weight:600;color:#fff;white-space:nowrap">' + gem.toFixed(1) + ' kg/sessie · ' + s.aantal + ' vis · ' + s.sessies + 'x</span></div></div></div>';
    }
    h += '</div>';
    return h;
  }

  const stekEntriesG = Object.entries(steken).filter(([k]) => k.match(/^G/i)).sort((a, b) => (b[1].gewicht / b[1].sessies) - (a[1].gewicht / a[1].sessies)).slice(0, 5);
  const stekEntriesAndere = Object.entries(steken).filter(([k]) => !k.match(/^G/i)).sort((a, b) => (b[1].gewicht / b[1].sessies) - (a[1].gewicht / a[1].sessies)).slice(0, 5);
  if (stekEntriesG.length || stekEntriesAndere.length) {
    html += '<div style="margin-bottom:20px">' +
      '<div style="font-size:13px;font-weight:700;color:#1e293b;margin-bottom:10px">Top 5 Stekken (gem. kg/sessie)</div>';
    html += renderTopStekken(stekEntriesG, 'G-stekken', '#3b82f6');
    html += renderTopStekken(stekEntriesAndere, 'Andere', '#64748b');
    html += '</div>';
  }

  const gemKgSessie = total.gewicht / data.length / 1000;
  const visPerUur = total.tijdMin > 0 ? (total.aantal / total.tijdMin * 60).toFixed(1) : '--';
  const kgPerUur = total.tijdMin > 0 ? (total.gewicht / total.tijdMin / 1000 * 60).toFixed(1) : '--';
  html += '<div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:10px;margin-bottom:20px">' +
    '<div style="background:#f8fafc;border-radius:8px;padding:12px;text-align:center">' +
      '<div style="font-size:11px;color:#64748b">Gem. kg/sessie</div>' +
      '<div style="font-size:18px;font-weight:700;color:#1e293b;margin-top:2px">' + gemKgSessie.toFixed(1) + ' kg</div></div>' +
    '<div style="background:#f8fafc;border-radius:8px;padding:12px;text-align:center">' +
      '<div style="font-size:11px;color:#64748b">Vis/uur</div>' +
      '<div style="font-size:18px;font-weight:700;color:#1e293b;margin-top:2px">' + visPerUur + '</div></div>' +
    '<div style="background:#f8fafc;border-radius:8px;padding:12px;text-align:center">' +
      '<div style="font-size:11px;color:#64748b">Kg/uur</div>' +
      '<div style="font-size:18px;font-weight:700;color:#1e293b;margin-top:2px">' + kgPerUur + '</div></div>' +
    '<div style="background:#f8fafc;border-radius:8px;padding:12px;text-align:center">' +
      '<div style="font-size:11px;color:#64748b">Totaal tijd</div>' +
      '<div style="font-size:18px;font-weight:700;color:#1e293b;margin-top:2px">' + fmtTime(total.tijdMin) + '</div></div>' +
  '</div>';

  el.innerHTML = html;
}

document.querySelectorAll('.tab').forEach(tab => {
  tab.addEventListener('click', () => {
    document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
    document.querySelectorAll('.panel').forEach(p => p.classList.remove('show'));
    tab.classList.add('active');
    document.getElementById('tab-' + tab.dataset.tab).classList.add('show');
  });
});

document.getElementById('btn-add').addEventListener('click', () => {
  const f = document.getElementById('add-form');
  f.classList.toggle('hidden');
  if (!f.classList.contains('hidden')) document.getElementById('f-datum').focus();
});
document.getElementById('btn-cancel-add').addEventListener('click', () => {
  document.getElementById('add-form').classList.add('hidden');
});
['f-begin', 'f-einde'].forEach(id => {
  const el = document.getElementById(id);
  el.addEventListener('blur', () => {
    el.value = formatTijdInput(el.value);
    updateFDuur();
  });
  el.addEventListener('input', updateFDuur);
});
function updateFDuur() {
  const d = calcDuurVanBeginEinde(
    document.getElementById('f-begin').value,
    document.getElementById('f-einde').value
  );
  if (d != null) {
    document.getElementById('f-duurMin').value = d;
  }
}
document.getElementById('btn-save-add').addEventListener('click', () => {
  function v(id) { return document.getElementById(id).value.trim(); }
  function n(id) { return parseInt(document.getElementById(id).value) || 0; }
  const jaar = huidigJaar();
  const datum = v('f-datum');
  if (!datum) { showToast('❌ Datum is verplicht', 'error'); return; }
  const month = deriveMonth(datum, jaar) || 'Onbekend';
  const fDuur = n('f-duurMin') || calcDuurVanBeginEinde(v('f-begin'), v('f-einde')) || 0;
  const row = {
    kroes: n('f-kroes'), schub: n('f-schub'), spiegel: n('f-spiegel'), ander: n('f-ander'),
    aantal: n('f-kroes') + n('f-schub') + n('f-spiegel') + n('f-ander'),
    gewicht: n('f-gewicht'),
    datum, stek: v('f-stek'), begin: v('f-begin'), einde: v('f-einde'),
    duurMin: fDuur,
    pijl: v('f-pijl'), beoordeling: v('f-beoordeling'),
    tijdMin: n('f-tijdMin') || fDuur,
    month, wedstrijd: document.getElementById('f-wedstrijd').checked ? '🏆' : ''
  };
  const data = loadData();
  const bestaand = data.findIndex(r => r.datum === datum && r.month === month);
  if (bestaand !== -1) {
    data[bestaand] = { ...data[bestaand], ...row };
    showToast('🔄 Bestaande sessie bijgewerkt');
  } else {
    data.push(row);
    showToast('✅ Sessie toegevoegd');
  }
  sortData(data);
  saveData(data);
  document.getElementById('add-form').classList.add('hidden');
  document.querySelectorAll('#add-form .form-input').forEach(i => i.value = '');
  document.getElementById('f-wedstrijd').checked = false;
  document.getElementById('f-kroes').value = '0';
  document.getElementById('f-schub').value = '0';
  document.getElementById('f-spiegel').value = '0';
  document.getElementById('f-ander').value = '0';
  document.getElementById('f-gewicht').value = '0';
  document.getElementById('f-duurMin').value = '0';
  render();
});

document.getElementById('btn-remove-empty').addEventListener('click', () => {
  let data = loadData();
  const before = data.length;
  data = data.filter(r => r.aantal > 0 || r.gewicht > 0);
  const removed = before - data.length;
  if (!removed) { showToast('ℹ️ Geen lege sessies'); return; }
  saveData(data);
  render();
  showToast(`🧹 ${removed} lege sessies verwijderd`);
});

document.getElementById('btn-remove-nodate').addEventListener('click', () => {
  let data = loadData();
  const before = data.length;
  data = data.filter(r => r.datum && r.datum.trim());
  const removed = before - data.length;
  if (!removed) { showToast('ℹ️ Alle rijen hebben een datum'); return; }
  saveData(data);
  render();
  showToast(`📅 ${removed} rijen zonder datum verwijderd`);
});

document.getElementById('btn-clear').addEventListener('click', () => {
  if (!confirm('Alle vissessies data wissen?')) return;
  if (!confirm('Zeker? Dit kan niet ongedaan gemaakt worden.')) return;
  localStorage.removeItem(STORAGE_KEY);
  render();
  showToast('✅ Data gewist');
});

