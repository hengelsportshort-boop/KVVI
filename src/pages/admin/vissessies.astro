const BACKUP_API = '/admin/api/vissessies-backup';

function backupStatus(msg, isError) {
  const el = document.getElementById('backup-status');
  el.textContent = msg;
  el.style.color = isError ? '#dc2626' : '#166534';
}

async function backupCreate() {
  backupStatus('🔄 Bezig met backup...');
  try {
    const res = await fetch(BACKUP_API, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ action: 'create' })
    });
    const json = await res.json();
    if (json.ok) {
      backupStatus('✅ Backup gemaakt: ' + json.file);
      showToast('✅ Backup gemaakt');
    } else {
      backupStatus('❌ ' + (json.error || 'Fout'), true);
    }
  } catch (e) {
    backupStatus('❌ ' + e.message, true);
  }
}

async function backupList() {
  const el = document.getElementById('backup-list');
  backupStatus('🔄 Backups ophalen...');
  try {
    const res = await fetch(BACKUP_API, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ action: 'list' })
    });
    const json = await res.json();
    if (json.backups && json.backups.length) {
      el.style.display = '';
      el.innerHTML = '<div style="font-weight:600;margin-bottom:4px">Beschikbare backups:</div>' +
        json.backups.map(f =>
          `<div style="display:flex;gap:8px;align-items:center;padding:3px 0;font-size:12px">
            <span>${f}</span>
            <button class="btn btn-outline" style="padding:2px 8px;font-size:11px" onclick="backupRestore('${f}')">Herstel</button>
            <button class="btn btn-outline" style="padding:2px 8px;font-size:11px" onclick="backupDownloadFile('${f}')">⬇️</button>
          </div>`
        ).join('');
      backupStatus('✅ ' + json.backups.length + ' backup(s) gevonden');
    } else {
      el.style.display = 'none';
      backupStatus('ℹ️ Geen backups gevonden');
    }
  } catch (e) {
    backupStatus('❌ ' + e.message, true);
  }
}

async function backupDownloadFile(file) {
  try {
    const res = await fetch(BACKUP_API, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ action: 'download', file })
    });
    if (!res.ok) { backupStatus('❌ Download mislukt', true); return; }
    const blob = await res.blob();
    const a = document.createElement('a');
    a.href = URL.createObjectURL(blob);
    a.download = file;
    a.click();
    URL.revokeObjectURL(a.href);
    backupStatus('✅ Download gestart: ' + file);
  } catch (e) {
    backupStatus('❌ ' + e.message, true);
  }
}

async function backupRestore(file) {
  if (!confirm('Herstel data van ' + file + '? Huidige data gaat verloren.')) return;
  backupStatus('🔄 Bezig met herstel van ' + file + '...');
  try {
    const res = await fetch(BACKUP_API, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ action: 'restore', file })
    });
    const json = await res.json();
    if (json.ok) {
      backupStatus('✅ Hersteld van ' + file + ' (' + json.count + ' sessies)');
      initFromAPI();
      showToast('✅ Data hersteld van ' + file);
    } else {
      backupStatus('❌ ' + (json.error || 'Fout'), true);
    }
  } catch (e) {
    backupStatus('❌ ' + e.message, true);
  }
}

async function backupDownload() {
  try {
    const res = await fetch(BACKUP_API, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ action: 'list' })
    });
    const json = await res.json();
    if (!json.backups || !json.backups.length) {
      backupStatus('ℹ️ Geen backups om te downloaden. Maak eerst een backup.');
      return;
    }
    backupStatus('📋 Kies een backup om te downloaden in de lijst');
    await backupList();
  } catch (e) {
    backupStatus('❌ ' + e.message, true);
  }
}

document.getElementById('btn-backup-create').addEventListener('click', backupCreate);
document.getElementById('btn-backup-list').addEventListener('click', backupList);
document.getElementById('btn-backup-download').addEventListener('click', backupDownload);
document.getElementById('btn-backup-upload').addEventListener('click', () => {
  document.getElementById('backup-file-input').click();
});
document.getElementById('backup-file-input').addEventListener('change', async (e) => {
  const file = e.target.files[0];
  if (!file) return;
  backupStatus('🔄 Bezig met uploaden...');
  try {
    const text = await file.text();
    const data = JSON.parse(text);
    if (!Array.isArray(data)) throw new Error('Bestand bevat geen geldige vissessies-data');
    const res = await fetch(BACKUP_API, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ action: 'upload', data })
    });
    const json = await res.json();
    if (json.ok) {
      backupStatus('✅ ' + json.count + ' sessies hersteld uit ' + file.name);
      initFromAPI();
      showToast('✅ Data hersteld uit ' + file.name);
    } else {
      backupStatus('❌ ' + (json.error || 'Fout'), true);
    }
  } catch (e) {
    backupStatus('❌ ' + e.message, true);
  }
  e.target.value = '';
});

function initJaarSelector() {
  const sel = document.getElementById('year-select');
  const actief = huidigJaar();
  sel.innerHTML = jaarOpties.map(y => `<option value="${y}"${y === actief ? ' selected' : ''}>${y}</option>`).join('');
  sel.addEventListener('change', () => {
    bewaarJaar(parseInt(sel.value));
    render();
  });
}

document.querySelector('.tab[data-tab="data"]').addEventListener('click', () => {
  const sel = document.getElementById('year-select');
  const actief = huidigJaar();
  if (parseInt(sel.value) !== actief) sel.value = actief;
});
document.querySelector('.tab[data-tab="stats"]').addEventListener('click', () => {
  const sel = document.getElementById('year-select');
  const actief = huidigJaar();
  if (parseInt(sel.value) !== actief) sel.value = actief;
});

function syncStatus(msg, isError) {
  var el = document.getElementById('sync-status');
  if (!el) return;
  el.textContent = msg;
  el.style.color = isError ? '#dc2626' : '#166534';
}
async function syncFromServer() {
  syncStatus('🔄 Data ophalen van server...');
  try {
    const res = await fetch(API_URL, { credentials: 'include' });
    if (!res.ok) throw new Error('Serverfout ' + res.status);
    const serverData = await res.json();
    if (!Array.isArray(serverData) || !serverData.length) { syncStatus('ℹ️ Geen data op server'); return; }
    sortData(serverData);
    saveData(serverData);
    render();
    syncStatus('✅ Vervangen door server data (' + serverData.length + ' sessies)');
    showToast('📡 Data vervangen van server');
  } catch (e) {
    syncStatus('❌ ' + e.message, true);
  }
}

document.getElementById('btn-sync-server').addEventListener('click', syncFromServer);

initJaarSelector();
render();
syncFromServer();
</script>
