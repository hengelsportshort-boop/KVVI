---
import Layout from '../../../../layouts/Layout.astro';
import { getWedstrijden, updateWedstrijd, type Wedstrijd } from '../../../../lib/kalenderManager';

export const prerender = false;

const { id } = Astro.params;
const pageTitle = "Wedstrijd Bewerken | KVVI Admin";

// Get the wedstrijd to edit
const wedstrijden = getWedstrijden();
const wedstrijd = wedstrijden.find(w => w.id === id);

if (!wedstrijd) {
  return Astro.redirect('/admin/kalender');
}

// Handle form submission
if (Astro.request.method === 'POST') {
  try {
    const formData = await Astro.request.formData();
    const datum = formData.get('datum') as string;
    const dag = formData.get('dag') as string;
    const reeks = formData.get('reeks') as string;
    
    // Validate required fields
    if (!datum || !dag || !reeks) {
      throw new Error('Alle velden zijn verplicht');
    }
    
    // Validate date format (DD/MM)
    if (!/^\d{2}\/\d{2}$/.test(datum)) {
      throw new Error('Datum moet in DD/MM formaat zijn');
    }
    
    updateWedstrijd(id, { datum, dag, reeks });
    
    // Redirect back to kalender page
    return Astro.redirect('/admin/kalender');
  } catch (error) {
    console.error('Error updating wedstrijd:', error);
  }
}
---

