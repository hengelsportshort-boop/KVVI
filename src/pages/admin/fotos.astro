---
import Layout from '../../layouts/Layout.astro';
export const prerender = false;

const pageTitle = "Fotobeheer | KVVI Admin";
---

<Layout title={pageTitle} noMainWrapper={true} hideNav={true}>
  <main class="h-screen flex flex-col bg-slate-50">
    <div class="md:hidden bg-[#003366] text-white p-4 flex justify-between items-center">
      <div>
        <h1 class="text-lg font-bold tracking-widest">KVVI ADMIN</h1>
        <p class="text-[10px] text-[#C5A059] font-bold">FOTOBEHEER</p>
      </div>
      <button id="mobile-menu-btn" class="p-2 hover:bg-white/10 rounded-lg transition">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7" />
        </svg>
      </button>
    </div>

    <div class="flex flex-1 min-h-0">
      <aside class="hidden md:flex w-64 bg-[#003366] text-white flex-col border-r-4 border-[#C5A059] fixed left-0 top-0 h-screen z-30">
        <div class="p-6 border-b border-white/10"><h1 class="text-xl font-bold tracking-widest">KVVI ADMIN</h1><p class="text-[10px] text-[#C5A059] font-bold">CONTROL PANEL</p></div>
        <nav class="flex-1 p-4 space-y-1 overflow-y-auto">
          <a href="/admin" class="flex items-center gap-3 p-3 hover:bg-white/5 rounded-lg transition-colors text-sm font-semibold"><span>🏠</span> Home</a>
          <a href="/admin/wedstrijden" class="flex items-center gap-3 p-3 hover:bg-white/5 rounded-lg transition-colors text-sm font-semibold"><span>🏆</span> Wedstrijden</a>
          <a href="/admin/kalender" class="flex items-center gap-3 p-3 hover:bg-white/5 rounded-lg transition-colors text-sm font-semibold"><span>📅</span> Kalender</a>
          <a href="/admin/visstekken" class="flex items-center gap-3 p-3 hover:bg-white/5 rounded-lg transition-colors text-sm font-semibold"><span>📍</span> Visstekken</a>
          <a href="/admin/visstekken-abc" class="flex items-center gap-3 p-3 hover:bg-white/5 rounded-lg transition-colors text-sm font-semibold"><span>🌐</span> ABC Visstekken</a>
          <a href="/admin/vissessies" class="flex items-center gap-3 p-3 hover:bg-white/5 rounded-lg transition-colors text-sm font-semibold"><span>📊</span> Vissessies</a>
          <a href="/admin/legende" class="flex items-center gap-3 p-3 hover:bg-white/5 rounded-lg transition-colors text-sm font-semibold"><span>📖</span> Legende</a>
          <a href="/admin/hengelshop" class="flex items-center gap-3 p-3 hover:bg-white/5 rounded-lg transition-colors text-sm font-semibold"><span>📦</span> Hengelshop</a>          
          <a href="/admin/koppelwedstrijden" class="flex items-center gap-3 p-3 hover:bg-white/5 rounded-lg transition-colors text-sm font-semibold"><span>🏆</span> Koppelwedstrijden</a>
          <a href="/admin/kamp-izegem" class="flex items-center gap-3 p-3 hover:bg-white/5 rounded-lg transition-colors text-sm font-semibold"><span>🏅</span> Kamp. Izegem</a>
          <a href="/admin/specials/vrouwvissing" class="flex items-center gap-3 p-3 hover:bg-white/5 rounded-lg transition-colors text-sm font-semibold"><span>👩</span> Vrouwvissing</a>
          <a href="/admin/specials/seniorenvissing" class="flex items-center gap-3 p-3 hover:bg-white/5 rounded-lg transition-colors text-sm font-semibold"><span>👴</span> Seniorenvissing</a>
          <a href="/admin/tips-tricks" class="flex items-center gap-3 p-3 hover:bg-white/5 rounded-lg transition-colors text-sm font-semibold"><span>💡</span> Tips &amp; Tricks</a>
          <a href="/admin/fotos" class="flex items-center gap-3 p-3 bg-white/10 rounded-lg border-l-4 border-[#C5A059] text-sm font-semibold"><span>📸</span> Foto's</a>
        </nav>
        <div class="p-4 border-t border-white/10"><a href="/" class="text-sm text-slate-400 hover:text-white transition-colors flex items-center gap-2"><span>←</span> Terug naar Website</a></div>
      </aside>

      <div id="mobile-overlay" class="fixed inset-0 bg-black/50 z-40 hidden" ></div>
      <aside id="mobile-sidebar" class="md:hidden fixed top-0 left-0 w-72 bg-[#003366] text-white z-50 flex-col border-r-4 border-[#C5A059] h-screen hidden shadow-2xl">
        <nav class="flex-1 p-4 space-y-1 pt-6">
          <a href="/admin" class="flex items-center gap-3 p-3 hover:bg-white/5 rounded-lg transition-colors text-sm font-semibold"><span>🏠</span> Home</a>
          <a href="/admin/wedstrijden" class="flex items-center gap-3 p-3 hover:bg-white/5 rounded-lg transition-colors text-sm font-semibold"><span>🏆</span> Wedstrijden</a>
          <a href="/admin/kalender" class="flex items-center gap-3 p-3 hover:bg-white/5 rounded-lg transition-colors text-sm font-semibold"><span>📅</span> Kalender</a>
          <a href="/admin/visstekken" class="flex items-center gap-3 p-3 hover:bg-white/5 rounded-lg transition-colors text-sm font-semibold"><span>📍</span> Visstekken</a>
          <a href="/admin/visstekken-abc" class="flex items-center gap-3 p-3 hover:bg-white/5 rounded-lg transition-colors text-sm font-semibold"><span>🌐</span> ABC Visstekken</a>
          <a href="/admin/vissessies" class="flex items-center gap-3 p-3 hover:bg-white/5 rounded-lg transition-colors text-sm font-semibold"><span>📊</span> Vissessies</a>
          <a href="/admin/legende" class="flex items-center gap-3 p-3 hover:bg-white/5 rounded-lg transition-colors text-sm font-semibold"><span>📖</span> Legende</a>
          <a href="/admin/hengelshop" class="flex items-center gap-3 p-3 hover:bg-white/5 rounded-lg transition-colors text-sm font-semibold"><span>📦</span> Hengelshop</a>          
          <a href="/admin/koppelwedstrijden" class="flex items-center gap-3 p-3 hover:bg-white/5 rounded-lg transition-colors text-sm font-semibold"><span>🏆</span> Koppelwedstrijden</a>
          <a href="/admin/kamp-izegem" class="flex items-center gap-3 p-3 hover:bg-white/5 rounded-lg transition-colors text-sm font-semibold"><span>🏅</span> Kamp. Izegem</a>
          <a href="/admin/specials/vrouwvissing" class="flex items-center gap-3 p-3 hover:bg-white/5 rounded-lg transition-colors text-sm font-semibold"><span>👩</span> Vrouwvissing</a>
          <a href="/admin/specials/seniorenvissing" class="flex items-center gap-3 p-3 hover:bg-white/5 rounded-lg transition-colors text-sm font-semibold"><span>👴</span> Seniorenvissing</a>
          <a href="/admin/tips-tricks" class="flex items-center gap-3 p-3 hover:bg-white/5 rounded-lg transition-colors text-sm font-semibold"><span>💡</span> Tips &amp; Tricks</a>
          <a href="/admin/fotos" class="flex items-center gap-3 p-3 bg-white/10 rounded-lg border-l-4 border-[#C5A059] text-sm font-semibold"><span>📸</span> Foto's</a>
        </nav>
        <div class="p-4 border-t border-white/10"><a href="/" class="text-sm text-slate-400 hover:text-white transition-colors flex items-center gap-2"><span>←</span> Terug</a></div>
      </aside>

      <section class="flex-1 flex flex-col min-h-0 md:ml-64">
        <header class="h-16 bg-white border-b border-slate-200 flex items-center justify-between px-6 md:px-8">
          <div class="flex items-center gap-3"><span class="text-slate-400 text-sm">Admin</span><span class="text-slate-300 text-sm">/</span><span class="font-semibold text-sm">Foto's</span></div>
          <div class="flex items-center gap-2">
            <span id="save-status" class="text-xs text-slate-400 hidden"></span>
          </div>
        </header>

        <div class="p-4 md:p-8 space-y-6 flex-1 overflow-y-auto">
          <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
            <div>
              <h1 class="text-2xl font-black text-[#003366] uppercase tracking-tight">Foto's beheren</h1>
              <p class="text-sm text-slate-500 mt-2">Upload, verwijder en beheer foto's voor de website.</p>
            </div>
            <div class="flex gap-2">
              <div class="bg-blue-50 border border-blue-200 rounded-lg px-4 py-2">
                <p class="text-xs text-blue-700 font-medium">📁 Fotos Home</p>
              </div>
              <div class="bg-green-50 border border-green-200 rounded-lg px-4 py-2">
                <p class="text-xs text-green-700 font-medium">📁 Foto Fotos</p>
              </div>
            </div>
          </div>

          <!-- Upload Sectie -->
          <div class="bg-white rounded-3xl border border-slate-200 shadow-sm p-4">
            <div class="flex items-center justify-between gap-4 pb-4 border-b border-slate-200 mb-4">
              <div>
                <p class="text-slate-500 text-xs uppercase tracking-wider font-bold">Foto Upload</p>
                <p class="text-lg font-black text-[#003366]">📤 Upload Nieuwe Foto</p>
              </div>
              <div class="text-right">
                <p class="text-slate-500 text-xs">Naar <strong>Foto Fotos</strong> map</p>
                <p class="text-slate-400 text-xs">JPG, PNG, WebP, GIF</p>
              </div>
            </div>
            
            <div class="border-2 border-dashed border-slate-300 rounded-2xl p-8 text-center hover:border-[#003366] transition-colors">
              <input type="file" id="file-input" accept="image/*" class="hidden" />
              <label for="file-input" class="cursor-pointer">
                <div class="mb-4">
                  <div class="w-16 h-16 bg-[#003366]/10 rounded-full flex items-center justify-center mx-auto mb-4">
                    <svg class="w-8 h-8 text-[#003366]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12" />
                    </svg>
                  </div>
                  <p class="text-sm font-medium text-slate-700">Klik om foto te uploaden</p>
                  <p class="text-xs text-slate-500 mt-1">of sleep en zet hier neer</p>
                </div>
              </label>
              <div id="upload-status" class="mt-4 text-sm hidden"></div>
            </div>
          </div>

          <!-- Foto Fotos Sectie -->
          <div class="bg-white rounded-3xl border border-slate-200 shadow-sm p-4">
            <div class="flex items-center justify-between gap-4 pb-4 border-b border-slate-200 mb-4">
              <div>
                <p class="text-slate-500 text-xs uppercase tracking-wider font-bold">Foto Fotos</p>
                <p class="text-2xl font-black text-[#003366]" id="foto-fotos-count">0</p>
              </div>
              <div class="text-right">
                <p class="text-slate-500 text-xs">Foto's uit <strong>Foto Fotos</strong> map</p>
                <p class="text-slate-400 text-xs">Upload & Delete</p>
              </div>
            </div>
            <div id="foto-fotos-list" class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4"></div>
          </div>

          <!-- Home Foto's Sectie -->
          <div class="bg-white rounded-3xl border border-slate-200 shadow-sm p-4">
            <div class="flex items-center justify-between gap-4 pb-4 border-b border-slate-200 mb-4">
              <div>
                <p class="text-slate-500 text-xs uppercase tracking-wider font-bold">Home Foto's</p>
                <p class="text-2xl font-black text-[#003366]" id="photo-count">0</p>
              </div>
              <div class="text-right">
                <p class="text-slate-500 text-xs">Foto's uit <strong>Fotos Home</strong> + uploads</p>
                <p class="text-slate-400 text-xs">Zichtbaarheid + upload</p>
              </div>
            </div>
            <div class="mb-4">
              <div class="border-2 border-dashed border-slate-300 rounded-2xl p-4 text-center hover:border-[#C5A059] transition-colors cursor-pointer" id="home-upload-area">
                <input type="file" id="home-file-input" accept="image/*" class="hidden" />
                <label for="home-file-input" class="cursor-pointer block">
                  <div class="flex items-center justify-center gap-2">
                    <svg class="w-5 h-5 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12" />
                    </svg>
                    <p class="text-sm font-medium text-slate-600">Upload naar <strong>Home Foto's</strong></p>
                  </div>
                </label>
                <div id="home-upload-status" class="mt-2 text-sm hidden"></div>
              </div>
            </div>
            <div id="photo-list" class="space-y-4"></div>
          </div>
        </div>
      </section>
    </div>
  </main>
</Layout>

<style>
  body { overflow-x: hidden; }
  ::-webkit-scrollbar { width: 6px; }
  ::-webkit-scrollbar-track { background: #f1f5f9; }
  ::-webkit-scrollbar-thumb { background: #94a3b8; border-radius: 3px; }
</style>

<script>
(() => {
  let items = [];
  let fotoFotosItems = [];
  const list = document.getElementById('photo-list');
  const fotoFotosList = document.getElementById('foto-fotos-list');
  const countEl = document.getElementById('photo-count');
  const fotoFotosCountEl = document.getElementById('foto-fotos-count');
  const saveStatus = document.getElementById('save-status');
  const uploadStatus = document.getElementById('upload-status');
  const fileInput = document.getElementById('file-input');

  async function loadData() {
    try {
      const res = await fetch('/api/gallery');
      const data = await res.json();
      
      // Filter alleen Fotos Home items
      items = data.filter(item => item.source === 'Fotos Home');
      render();
    } catch (error) {
      list.innerHTML = '<div class="p-6 text-center text-red-500">Fout bij laden van foto&#39;s.</div>';
    }
    
    await loadFotoFotos();
  }

  async function loadFotoFotos() {
    try {
      // Load Foto Fotos items via API
      const res = await fetch('/api/gallery');
      const data = await res.json();
      
      // Get Foto Fotos files using source field
      fotoFotosItems = data.filter(item => item.source === 'Foto Fotos');
      renderFotoFotos();
    } catch (error) {
      fotoFotosList.innerHTML = '<div class="p-6 text-center text-red-500">Fout bij laden van Foto Fotos.</div>';
    }
  }

  function render() {
    countEl.textContent = String(items.length);
    if (!items.length) {
      list.innerHTML = '<div class="p-8 text-center text-slate-400 italic border-2 border-dashed border-slate-200 rounded-xl">Geen foto&#39;s in de "Fotos Home" map.</div>';
      return;
    }

    let html = '';
    items.forEach((item, idx) => {
      const isSeedPhoto = item.id && item.id.startsWith('home-photo-');
      const isUploadedPhoto = item.id && item.id.startsWith('home-upload-');
      const typeLabel = isSeedPhoto ? 'Seed foto' : (isUploadedPhoto ? 'Geüpload' : 'Externe URL');
      const typeClass = isSeedPhoto ? 'bg-green-100 text-green-700' : (isUploadedPhoto ? 'bg-blue-100 text-blue-700' : 'bg-yellow-100 text-yellow-700');
      html += `<div class="border border-slate-200 rounded-3xl overflow-hidden shadow-sm" data-home-idx="${idx}">
        <div class="grid grid-cols-1 lg:grid-cols-[250px_1fr] gap-4">
          <div class="h-48 lg:h-full bg-slate-100 overflow-hidden">
            <img src="${item.src}" alt="${escapeHtml(item.titel || 'Foto')}" class="w-full h-full object-cover" />
          </div>
          <div class="p-4 space-y-3">
            <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
              <div>
                <p class="text-xs uppercase tracking-wider text-slate-500">${escapeHtml(item.titel || 'Onbekende foto')}</p>
                <p class="text-slate-600 text-sm">${escapeHtml(item.src)}</p>
                <span class="inline-block mt-1 px-2 py-1 ${typeClass} text-xs rounded-full font-medium">${typeLabel}</span>
              </div>
              <div class="flex items-center gap-2">
                <label class="flex items-center gap-2 text-sm font-semibold text-slate-700">
                  <input type="checkbox" class="visibility-toggle" ${item.zichtbaar ? 'checked' : ''}>
                  zichtbaar
                </label>
                ${isUploadedPhoto ? '<button class="delete-home-upload bg-red-500 text-white text-xs font-bold px-3 py-2 rounded-lg hover:bg-red-600 transition">🗑️ Verwijder</button>' : ''}
                ${!isSeedPhoto && !isUploadedPhoto ? '<button class="delete-btn bg-red-50 text-red-600 text-xs font-bold px-3 py-2 rounded-lg border border-red-200 hover:bg-red-100 transition">Verwijderen</button>' : ''}
              </div>
            </div>
            ${isSeedPhoto ? '<div class="text-xs text-slate-400 italic">Lokale seed foto — kan niet worden verwijderd.</div>' : ''}
            ${isUploadedPhoto ? '<div class="text-xs text-slate-400 italic">Geüploade foto — verwijderen verwijdert het bestand.</div>' : ''}
            ${!isSeedPhoto && !isUploadedPhoto ? `
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
              <label class="block text-xs text-slate-500 uppercase tracking-wider">Titel</label>
              <input type="text" class="photo-title w-full rounded-lg border border-slate-200 px-3 py-2 text-sm" value="${escapeHtml(item.titel)}" />
            </div>
            <div class="grid grid-cols-1 gap-3">
              <label class="block text-xs text-slate-500 uppercase tracking-wider">URL</label>
              <input type="text" class="photo-src w-full rounded-lg border border-slate-200 px-3 py-2 text-sm" value="${escapeHtml(item.src)}" />
            </div>` : ''}
          </div>
        </div>
      </div>`;
    });

    list.innerHTML = html;
    bindEvents();
  }

  function renderFotoFotos() {
    fotoFotosCountEl.textContent = String(fotoFotosItems.length);
    if (!fotoFotosItems.length) {
      fotoFotosList.innerHTML = '<div class="col-span-full p-8 text-center text-slate-400 italic border-2 border-dashed border-slate-200 rounded-xl">Geen foto&#39;s in de "Foto Fotos" map.</div>';
      return;
    }

    let html = '';
    fotoFotosItems.forEach((item, idx) => {
      const filename = item.src.split('/').pop();
      html += `<div class="relative group">
        <div class="aspect-square bg-slate-100 rounded-xl overflow-hidden border border-slate-200">
          <img src="${item.src}" alt="${escapeHtml(item.titel || 'Foto')}" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" />
        </div>
        <div class="absolute inset-0 bg-black/50 opacity-0 group-hover:opacity-100 transition-opacity duration-300 rounded-xl flex items-center justify-center">
          <button class="delete-foto-foto bg-red-500 text-white text-xs font-bold px-3 py-2 rounded-lg hover:bg-red-600 transition" data-filename="${encodeURIComponent(filename)}">
            🗑️ Verwijder
          </button>
        </div>
        <div class="mt-2">
          <p class="text-xs text-slate-600 truncate">${escapeHtml(filename)}</p>
        </div>
      </div>`;
    });

    fotoFotosList.innerHTML = html;
    bindFotoFotosEvents();
  }

  function escapeHtml(text) {
    const d = document.createElement('div');
    d.textContent = text;
    return d.innerHTML;
  }

  function bindEvents() {
    list.querySelectorAll('.photo-title').forEach((input, idx) => {
      if (!input) return;
      input.addEventListener('change', () => {
        if (items[idx]) items[idx].titel = input.value.trim();
        scheduleSave();
      });
    });
    list.querySelectorAll('.photo-src').forEach((input, idx) => {
      if (!input) return;
      input.addEventListener('change', () => {
        if (items[idx]) items[idx].src = input.value.trim();
        scheduleSave();
      });
    });
    list.querySelectorAll('.visibility-toggle').forEach((input, idx) => {
      input.addEventListener('change', () => {
        if (items[idx]) items[idx].zichtbaar = input.checked;
        scheduleSave();
      });
    });
    list.querySelectorAll('.delete-btn').forEach((button, idx) => {
      button.addEventListener('click', () => {
        if (confirm('Foto verwijderen?')) {
          items.splice(idx, 1);
          render();
          scheduleSave();
        }
      });
    });
    list.querySelectorAll('.delete-home-upload').forEach(button => {
      button.addEventListener('click', async () => {
        const parent = button.closest('[data-home-idx]');
        const idx = Number(parent?.dataset.homeIdx);
        const item = items[idx];
        if (!item) return;
        const filename = decodeURIComponent(item.src.split('/').pop());
        if (confirm(`Geüploade foto "${filename}" verwijderen?`)) {
          try {
            const res = await fetch(`/api/gallery?filename=${encodeURIComponent(filename)}`, { method: 'DELETE' });
            const result = await res.json();
            if (result.success) {
              showStatus('✅ Verwijderd', 'text-green-600');
              await loadData();
            } else {
              showStatus('❌ Fout bij verwijderen', 'text-red-600');
            }
          } catch (error) {
            showStatus('❌ Fout bij verwijderen', 'text-red-600');
          }
        }
      });
    });
  }

  let saveTimeout;
  function scheduleSave() {
    clearTimeout(saveTimeout);
    saveTimeout = setTimeout(saveData, 500);
  }

  async function saveData() {
    try {
      const res = await fetch('/api/gallery', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(items)
      });
      const result = await res.json();
      if (result.success) showStatus('✅ Opgeslagen', 'text-green-600');
      else showStatus('❌ Fout bij opslaan', 'text-red-600');
    } catch (error) {
      showStatus('❌ Fout bij opslaan', 'text-red-600');
    }
  }

  function showStatus(message, cls) {
    saveStatus.textContent = message;
    saveStatus.className = `text-xs ${cls} font-bold`;
    saveStatus.classList.remove('hidden');
    clearTimeout(saveTimeout);
    saveTimeout = setTimeout(() => saveStatus.classList.add('hidden'), 2000);
  }

  function bindFotoFotosEvents() {
    fotoFotosList.querySelectorAll('.delete-foto-foto').forEach(button => {
      button.addEventListener('click', async () => {
        const filename = decodeURIComponent(button.dataset.filename);
        if (confirm(`Foto "${filename}" verwijderen?`)) {
          try {
            const res = await fetch(`/api/gallery?filename=${encodeURIComponent(filename)}`, {
              method: 'DELETE'
            });
            const result = await res.json();
            if (result.success) {
              showUploadStatus('✅ Foto verwijderd', 'text-green-600');
              await loadFotoFotos();
            } else {
              showUploadStatus('❌ Fout bij verwijderen', 'text-red-600');
            }
          } catch (error) {
            showUploadStatus('❌ Fout bij verwijderen', 'text-red-600');
          }
        }
      });
    });
  }

  // Upload functionality — Foto Fotos
  fileInput.addEventListener('change', async (e) => {
    const file = e.target.files[0];
    if (file) {
      await uploadFile(file, 'fotos');
    }
  });

  const uploadArea = fileInput.parentElement.parentElement;
  uploadArea.addEventListener('dragover', (e) => {
    e.preventDefault();
    uploadArea.classList.add('border-[#003366]', 'bg-[#003366]/5');
  });

  uploadArea.addEventListener('dragleave', (e) => {
    e.preventDefault();
    uploadArea.classList.remove('border-[#003366]', 'bg-[#003366]/5');
  });

  uploadArea.addEventListener('drop', async (e) => {
    e.preventDefault();
    uploadArea.classList.remove('border-[#003366]', 'bg-[#003366]/5');
    const files = e.dataTransfer.files;
    if (files.length > 0) {
      await uploadFile(files[0], 'fotos');
    }
  });

  // Upload functionality — Home Foto's
  const homeFileInput = document.getElementById('home-file-input');
  const homeUploadArea = document.getElementById('home-upload-area');
  const homeUploadStatus = document.getElementById('home-upload-status');

  homeFileInput.addEventListener('change', async (e) => {
    const file = e.target.files[0];
    if (file) {
      await uploadFile(file, 'home');
    }
  });

  homeUploadArea.addEventListener('dragover', (e) => {
    e.preventDefault();
    homeUploadArea.classList.add('border-[#C5A059]', 'bg-amber-50');
  });

  homeUploadArea.addEventListener('dragleave', (e) => {
    e.preventDefault();
    homeUploadArea.classList.remove('border-[#C5A059]', 'bg-amber-50');
  });

  homeUploadArea.addEventListener('drop', async (e) => {
    e.preventDefault();
    homeUploadArea.classList.remove('border-[#C5A059]', 'bg-amber-50');
    const files = e.dataTransfer.files;
    if (files.length > 0) {
      await uploadFile(files[0], 'home');
    }
  });

  async function uploadFile(file, category) {
    const statusEl = category === 'home' ? homeUploadStatus : uploadStatus;
    showStatusMsg(statusEl, '⏳ Uploaden...', 'text-blue-600');
    
    const formData = new FormData();
    formData.append('file', file);
    formData.append('category', category);
    
    try {
      const res = await fetch('/api/gallery', {
        method: 'POST',
        body: formData
      });
      
      const result = await res.json();
      if (result.success) {
        showStatusMsg(statusEl, '✅ Foto succesvol geüpload', 'text-green-600');
        if (category === 'home') {
          homeFileInput.value = '';
          await loadData();
        } else {
          fileInput.value = '';
          await loadFotoFotos();
        }
      } else {
        showStatusMsg(statusEl, `❌ ${result.error}`, 'text-red-600');
      }
    } catch (error) {
      showStatusMsg(statusEl, '❌ Fout bij uploaden', 'text-red-600');
    }
  }

  function showStatusMsg(el, message, cls) {
    el.textContent = message;
    el.className = `mt-4 text-sm ${cls} font-medium`;
    el.classList.remove('hidden');
    setTimeout(() => el.classList.add('hidden'), 3000);
  }

  const menuBtn = document.getElementById('mobile-menu-btn');
  const sidebar = document.getElementById('mobile-sidebar');
  const overlay = document.getElementById('mobile-overlay');
  if (menuBtn && sidebar && overlay) {
    function toggleMenu() {
      const hidden = sidebar.classList.contains('hidden');
      sidebar.classList.toggle('hidden', !hidden);
      overlay.classList.toggle('hidden', !hidden);
    }
    menuBtn.onclick = toggleMenu;
    overlay.onclick = toggleMenu;
  }

  loadData();
})();
</script>