---
import Layout from '../../layouts/Layout.astro';
export const prerender = false;

const pageTitle = "Tips & Tricks Beheer | KVVI Admin";
---

<Layout title={pageTitle} noMainWrapper={true} hideNav={true}>
  <main class="h-screen flex flex-col bg-slate-50">
    <div class="md:hidden bg-[#003366] text-white p-4 flex justify-between items-center">
      <div>
        <h1 class="text-lg font-bold tracking-widest">KVVI ADMIN</h1>
        <p class="text-[10px] text-[#C5A059] font-bold">TIPS & TRICKS</p>
      </div>
      <button id="mobile-menu-btn" class="p-2 hover:bg-white/10 rounded-lg transition">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7" />
        </svg>
      </button>
    </div>
    <div class="flex flex-1 min-h-0">
      <aside class="hidden md:flex w-64 bg-[#003366] text-white flex-col border-r-4 border-[#C5A059] fixed left-0 top-0 h-screen z-30">
        <div class="p-6 border-b border-white/10"><h1 class="text-xl font-bold tracking-widest">KVVI ADMIN</h1><p class="text-[10px] text-[#C5A059] font-bold">CONTROL PANEL</p></div>
        <nav class="flex-1 p-4 space-y-1 overflow-y-auto">
          <a href="/admin" class="flex items-center gap-3 p-3 hover:bg-white/5 rounded-lg transition-colors text-sm font-semibold"><span>🏠</span> Home</a>
          <a href="/admin/wedstrijden" class="flex items-center gap-3 p-3 hover:bg-white/5 rounded-lg transition-colors text-sm font-semibold"><span>🏆</span> Wedstrijden</a>
          <a href="/admin/kalender" class="flex items-center gap-3 p-3 hover:bg-white/5 rounded-lg transition-colors text-sm font-semibold"><span>📅</span> Kalender</a>
          <a href="/admin/visstekken" class="flex items-center gap-3 p-3 hover:bg-white/5 rounded-lg transition-colors text-sm font-semibold"><span>📍</span> Visstekken</a>
          <a href="/admin/visstekken-abc" class="flex items-center gap-3 p-3 hover:bg-white/5 rounded-lg transition-colors text-sm font-semibold"><span>🌐</span> ABC Visstekken</a>
          <a href="/admin/vissessies" class="flex items-center gap-3 p-3 hover:bg-white/5 rounded-lg transition-colors text-sm font-semibold"><span>📊</span> Vissessies</a>
          <a href="/admin/legende" class="flex items-center gap-3 p-3 hover:bg-white/5 rounded-lg transition-colors text-sm font-semibold"><span>📖</span> Legende</a>
          <a href="/admin/hengelshop" class="flex items-center gap-3 p-3 hover:bg-white/5 rounded-lg transition-colors text-sm font-semibold"><span>📦</span> Hengelshop</a>
          <a href="/admin/koppelwedstrijden" class="flex items-center gap-3 p-3 hover:bg-white/5 rounded-lg transition-colors text-sm font-semibold"><span>🏆</span> Koppelwedstrijden</a>
          <a href="/admin/kamp-izegem" class="flex items-center gap-3 p-3 hover:bg-white/5 rounded-lg transition-colors text-sm font-semibold"><span>🏅</span> Kamp. Izegem</a>
          <a href="/admin/specials/vrouwvissing" class="flex items-center gap-3 p-3 hover:bg-white/5 rounded-lg transition-colors text-sm font-semibold"><span>👩</span> Vrouwvissing</a>
          <a href="/admin/specials/seniorenvissing" class="flex items-center gap-3 p-3 hover:bg-white/5 rounded-lg transition-colors text-sm font-semibold"><span>👴</span> Seniorenvissing</a>
          <a href="/admin/tips-tricks" class="flex items-center gap-3 p-3 bg-white/10 rounded-lg border-l-4 border-[#C5A059] text-sm font-semibold"><span>💡</span> Tips &amp; Tricks</a>
          <a href="/admin/fotos" class="flex items-center gap-3 p-3 hover:bg-white/5 rounded-lg transition-colors text-sm font-semibold"><span>📸</span> Foto's</a>
        </nav>
        <div class="p-4 border-t border-white/10"><a href="/" class="text-sm text-slate-400 hover:text-white transition-colors flex items-center gap-2"><span>←</span> Terug naar Website</a></div>
      </aside>
      <div id="mobile-overlay" class="fixed inset-0 bg-black/50 z-40 hidden" ></div>
      <aside id="mobile-sidebar" class="md:hidden fixed top-0 left-0 w-72 bg-[#003366] text-white z-50 flex-col border-r-4 border-[#C5A059] h-screen hidden shadow-2xl">
        <nav class="flex-1 p-4 space-y-1 pt-6">
          <a href="/admin" class="flex items-center gap-3 p-3 hover:bg-white/5 rounded-lg transition-colors text-sm font-semibold"><span>🏠</span> Home</a>
          <a href="/admin/wedstrijden" class="flex items-center gap-3 p-3 hover:bg-white/5 rounded-lg transition-colors text-sm font-semibold"><span>🏆</span> Wedstrijden</a>
          <a href="/admin/kalender" class="flex items-center gap-3 p-3 hover:bg-white/5 rounded-lg transition-colors text-sm font-semibold"><span>📅</span> Kalender</a>
          <a href="/admin/visstekken" class="flex items-center gap-3 p-3 hover:bg-white/5 rounded-lg transition-colors text-sm font-semibold"><span>📍</span> Visstekken</a>
          <a href="/admin/visstekken-abc" class="flex items-center gap-3 p-3 hover:bg-white/5 rounded-lg transition-colors text-sm font-semibold"><span>🌐</span> ABC Visstekken</a>
          <a href="/admin/vissessies" class="flex items-center gap-3 p-3 hover:bg-white/5 rounded-lg transition-colors text-sm font-semibold"><span>📊</span> Vissessies</a>
          <a href="/admin/legende" class="flex items-center gap-3 p-3 hover:bg-white/5 rounded-lg transition-colors text-sm font-semibold"><span>📖</span> Legende</a>
          <a href="/admin/hengelshop" class="flex items-center gap-3 p-3 hover:bg-white/5 rounded-lg transition-colors text-sm font-semibold"><span>📦</span> Hengelshop</a>
          <a href="/admin/koppelwedstrijden" class="flex items-center gap-3 p-3 hover:bg-white/5 rounded-lg transition-colors text-sm font-semibold"><span>🏆</span> Koppelwedstrijden</a>
          <a href="/admin/kamp-izegem" class="flex items-center gap-3 p-3 hover:bg-white/5 rounded-lg transition-colors text-sm font-semibold"><span>🏅</span> Kamp. Izegem</a>
          <a href="/admin/specials/vrouwvissing" class="flex items-center gap-3 p-3 hover:bg-white/5 rounded-lg transition-colors text-sm font-semibold"><span>👩</span> Vrouwvissing</a>
          <a href="/admin/specials/seniorenvissing" class="flex items-center gap-3 p-3 hover:bg-white/5 rounded-lg transition-colors text-sm font-semibold"><span>👴</span> Seniorenvissing</a>
          <a href="/admin/tips-tricks" class="flex items-center gap-3 bg-white/10 rounded-lg border-l-4 border-[#C5A059] text-sm font-semibold"><span>💡</span> Tips &amp; Tricks</a>
          <a href="/admin/fotos" class="flex items-center gap-3 p-3 hover:bg-white/5 rounded-lg transition-colors text-sm font-semibold"><span>📸</span> Foto's</a>
        </nav>
        <div class="p-4 border-t border-white/10"><a href="/" class="text-sm text-slate-400 hover:text-white transition-colors flex items-center gap-2"><span>←</span> Terug</a></div>
      </aside>
      <section class="flex-1 flex flex-col min-h-0 md:ml-64">
        <header class="h-16 bg-white border-b border-slate-200 flex items-center justify-between px-6 md:px-8">
          <div class="flex items-center gap-3"><span class="text-slate-400 text-sm">Admin</span><span class="text-slate-300 text-sm">/</span><span class="font-semibold text-sm">Tips &amp; Tricks</span></div>
          <div>
            <span id="save-status" class="text-xs text-slate-400 hidden"></span>
          </div>
        </header>
        <div class="p-4 md:p-6 space-y-4 flex-1 overflow-y-auto">

          <div class="flex items-center justify-between">
            <p class="text-xs text-slate-500">Beheer de Tips &amp; Tricks. <span id="count-nr" class="font-bold text-[#003366]">0</span> tips</p>
            <button id="add-btn" class="bg-[#003366] text-white text-xs font-bold px-4 py-2 rounded-lg hover:bg-[#002244] transition">➕ Nieuwe Tip</button>
          </div>

          <div id="page-visibility" class="bg-white rounded-xl border border-slate-200 p-4 flex items-center gap-3">
            <input type="checkbox" id="page-visible" class="w-4 h-4 rounded border-slate-300 text-[#003366] focus:ring-[#003366]" />
            <label for="page-visible" class="text-sm font-semibold text-slate-700 cursor-pointer select-none">Pagina zichtbaar op website</label>
          </div>

          <div id="tips-list" class="space-y-3">
          </div>

        </div>
      </section>
    </div>
  </main>
</Layout>

<style is:global>
  body { overflow-x: hidden; }
  ::-webkit-scrollbar { width: 6px; }
  ::-webkit-scrollbar-thumb { background: #94a3b8; border-radius: 3px; }
  .tip-card textarea { min-height: 80px; resize: vertical; font-family: inherit; }
  .tip-card input[type="text"],
  .tip-card input[type="url"],
  .tip-card textarea { font-size: 13px; }
</style>

<script>
(function() {
  let data = null;
  let nextId = 1;
  let saveTimeout = null;

  const container = document.getElementById('tips-list');
  const countNr = document.getElementById('count-nr');
  const addBtn = document.getElementById('add-btn');
  const pageVisibleCheck = document.getElementById('page-visible');
  const saveStatus = document.getElementById('save-status');

  async function loadData() {
    try {
      const res = await fetch('/api/tips-tricks');
      data = await res.json();
      if (!data.tips) data.tips = [];
      nextId = data.tips.reduce((max, t) => Math.max(max, t.id || 0), 0) + 1;
      render();
    } catch (e) {
      container.innerHTML = '<div class="text-red-400 text-sm p-4">Fout bij laden: ' + e.message + '</div>';
    }
  }

  function render() {
    pageVisibleCheck.checked = data.pageVisible !== false;
    countNr.textContent = data.tips.length;
    if (!data.tips.length) {
      container.innerHTML = '<div class="text-center text-slate-400 py-10 italic border-2 border-dashed border-slate-200 rounded-xl">Nog geen tips. Klik op "Nieuwe Tip" om te beginnen.</div>';
      return;
    }
    container.innerHTML = data.tips.map(function(tip, i) {
      return '<div class="tip-card bg-white rounded-xl border border-slate-200 p-4 space-y-3" data-index="' + i + '">' +
        '<div class="flex items-center justify-between">' +
          '<input type="checkbox" id="tip-vis-' + tip.id + '" ' + (tip.visible !== false ? 'checked' : '') + ' class="w-4 h-4 rounded border-slate-300 text-[#003366] focus:ring-[#003366]" onchange="window._ttData.tips[' + i + '].visible = this.checked; scheduleSave()" />' +
          '<label for="tip-vis-' + tip.id + '" class="text-xs font-semibold text-slate-500 cursor-pointer select-none mr-auto ml-2">Zichtbaar</label>' +
          '<button class="text-red-500 hover:text-red-700 text-sm font-bold px-2 py-1" onclick="verwijderTip(' + i + ')">✕ Verwijderen</button>' +
        '</div>' +
        '<div>' +
          '<label class="text-xs font-bold text-slate-400 uppercase tracking-wider block mb-1">Naam</label>' +
          '<input type="text" value="' + (tip.name || '').replace(/"/g,'&quot;') + '" class="w-full px-3 py-2 rounded-lg border border-slate-200 text-sm" onchange="window._ttData.tips[' + i + '].name = this.value; scheduleSave()" placeholder="Titel van de tip" />' +
        '</div>' +
        '<div>' +
          '<label class="text-xs font-bold text-slate-400 uppercase tracking-wider block mb-1">Info</label>' +
          '<textarea class="w-full px-3 py-2 rounded-lg border border-slate-200 text-sm" onchange="window._ttData.tips[' + i + '].info = this.value; scheduleSave()" placeholder="Beschrijving (optioneel)">' + (tip.info || '').replace(/</g,'&lt;').replace(/>/g,'&gt;') + '</textarea>' +
        '</div>' +
        '<div>' +
          '<label class="text-xs font-bold text-slate-400 uppercase tracking-wider block mb-1">Link (URL)</label>' +
          '<input type="url" value="' + (tip.link || '').replace(/"/g,'&quot;') + '" class="w-full px-3 py-2 rounded-lg border border-slate-200 text-sm" onchange="window._ttData.tips[' + i + '].link = this.value; scheduleSave()" placeholder="https://..." />' +
        '</div>' +
        '<div>' +
          '<label class="text-xs font-bold text-slate-400 uppercase tracking-wider block mb-1">Media (foto URL of YouTube-link)</label>' +
          '<input type="url" value="' + (tip.mediaUrl || '').replace(/"/g,'&quot;') + '" class="w-full px-3 py-2 rounded-lg border border-slate-200 text-sm" onchange="window._ttData.tips[' + i + '].mediaUrl = this.value; scheduleSave()" placeholder="https://..." />' +
        '</div>' +
        (tip.mediaUrl ? '<div class="text-xs text-slate-400">📎 ' + tip.mediaUrl + '</div>' : '') +
      '</div>';
    }).join('');
  }

  window.scheduleSave = function() {
    clearTimeout(saveTimeout);
    saveTimeout = setTimeout(save, 600);
  };

  window.verwijderTip = function(index) {
    if (!confirm('Verwijder deze tip?')) return;
    data.tips.splice(index, 1);
    render();
    scheduleSave();
  };

  async function save() {
    data.pageVisible = pageVisibleCheck.checked;
    saveStatus.textContent = 'Opslaan...';
    saveStatus.classList.remove('hidden');
    try {
      const res = await fetch('/api/tips-tricks', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
      });
      if (res.ok) {
        saveStatus.textContent = '✓ Opgeslagen';
        saveStatus.className = 'text-xs text-green-600';
      } else {
        saveStatus.textContent = '✗ Fout bij opslaan';
        saveStatus.className = 'text-xs text-red-600';
      }
    } catch (e) {
      saveStatus.textContent = '✗ Fout: ' + e.message;
      saveStatus.className = 'text-xs text-red-600';
    }
    setTimeout(function() { saveStatus.classList.add('hidden'); }, 2000);
  }

  addBtn.addEventListener('click', function() {
    data.tips.push({
      id: nextId++,
      name: '',
      info: '',
      link: '',
      mediaUrl: '',
      visible: true
    });
    render();
    scheduleSave();
  });

  pageVisibleCheck.addEventListener('change', scheduleSave);

  window._ttData = data;

  loadData();
})();
</script>
